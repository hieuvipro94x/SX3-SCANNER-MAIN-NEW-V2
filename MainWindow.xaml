<Window x:Class="SX3_SCANER.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SX3_SCANER"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:viewmodel="clr-namespace:SX3_SCANER.ViewModel"
        d:DataContext="{d:DesignInstance Type=viewmodel:MainViewModel}"
        Style="{StaticResource MaterialDesignWindow}"
        mc:Ignorable="d"
        Title="SX3 Scanner"
        Height="700"
        Width="1180"
        MinHeight="540"
        MinWidth="920"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="CanResize"
        SizeToContent="Manual"
        FontFamily="Segoe UI"
        Background="#F8FAFC"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#1D4ED8" />
        <SolidColorBrush x:Key="TextMainBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#64748B" />
        <SolidColorBrush x:Key="InputBgBrush" Color="#FAFBFD" />
        <SolidColorBrush x:Key="OkBrush" Color="#16A34A" />
        <SolidColorBrush x:Key="NgBrush" Color="#DC2626" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style TargetType="materialDesign:Card">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="UniformCornerRadius" Value="12" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Margin" Value="6" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="3" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Background" Value="{StaticResource InputBgBrush}" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="3" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Background" Value="{StaticResource InputBgBrush}" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Margin" Value="3" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Background" Value="{StaticResource InputBgBrush}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryDarkBrush}" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E0E7EF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RowHeight" Value="32" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC" />
            <Setter Property="HorizontalGridLinesBrush" Value="#E6EDF5" />
            <Setter Property="VerticalGridLinesBrush" Value="#E6EDF5" />
            <Setter Property="EnableRowVirtualization" Value="True" />
            <Setter Property="EnableColumnVirtualization" Value="True" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F1F5F9" />
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="6,0" />
        </Style>

        <local:ScanRowBackgroundBrushConverter x:Key="ScanRowBackgroundBrushConverter"/>
        <local:ScanRowForegroundBrushConverter x:Key="ScanRowForegroundBrushConverter"/>

        <Style x:Key="UnifiedScanDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style x:Key="UnifiedScanRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="{Binding Converter={StaticResource ScanRowBackgroundBrushConverter}}"/>
            <Setter Property="Foreground" Value="{Binding Converter={StaticResource ScanRowForegroundBrushConverter}}"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0F2FE"/>
                    <Setter Property="Foreground" Value="#0F172A"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,8" />
        </Style>


        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1565C0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style x:Key="SubFieldLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource FieldLabelStyle}">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#90A4AE" />
            <Setter Property="Margin" Value="12,0,0,0" />
        </Style>
        <Style x:Key="ExpectedValueBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFDE7" />
            <Setter Property="BorderBrush" Value="#F1E9A8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="MinHeight" Value="36" />
        </Style>
        <Style x:Key="ExpectedValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#0D47A1" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="ScanResultTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#16A34A" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#E3EAF2" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="10,3" />
        </Style>
        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="32" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
    </Window.Resources>
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="69*"/>
            <ColumnDefinition Width="571*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="White"
                BorderBrush="#E0E7EF"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="1"
                      x:Name="topAnnouncementArea"
                      Margin="8,0,14,0"
                      HorizontalAlignment="Stretch">
                    <Border x:Name="onlineAnnouncementHost"
                             Width="{Binding ActualWidth, ElementName=topAnnouncementArea}"
                             MinWidth="760"
                             MaxWidth="1300"
                            Height="42"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            CornerRadius="11"
                            Padding="12,4"
                            BorderThickness="2"
                            Background="{Binding OnlineAnnouncementBackground}"
                            BorderBrush="{Binding OnlineAnnouncementBorderBrush}">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12"
                                              ShadowDepth="0"
                                              Opacity="0.35" />
                        </Border.Effect>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOnlineAnnouncementVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Grid ClipToBounds="True"
                              VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="38" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding OnlineAnnouncementIcon}"
                                       Foreground="{Binding OnlineAnnouncementForeground}"
                                       FontFamily="Segoe UI Emoji"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />

                            <TextBlock Grid.Column="1"
                                       Margin="6,0,12,0"
                                       Text="{Binding OnlineAnnouncementTitle, StringFormat={}{0}:}"
                                       Foreground="{Binding OnlineAnnouncementForeground}"
                                       FontFamily="Segoe UI"
                                       FontSize="14"
                                       FontWeight="ExtraBold"
                                       VerticalAlignment="Center"
                                       TextWrapping="NoWrap" />

                            <Canvas Grid.Column="2"
                                    x:Name="AnnouncementMarqueeHost"
                                    Margin="0,0,8,0"
                                    ClipToBounds="True"
                                    VerticalAlignment="Stretch">
                                <TextBlock x:Name="AnnouncementMarqueeText"
                                           Text="{Binding OnlineAnnouncementText}"
                                           Canvas.Top="6"
                                           FontFamily="Segoe UI"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{Binding OnlineAnnouncementForeground}"
                                           TextWrapping="NoWrap">
                                    <TextBlock.RenderTransform>
                                        <TranslateTransform x:Name="AnnouncementMarqueeTransform" />
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Canvas>

                            <StackPanel Grid.Column="3"
                                        Margin="6,0,0,0"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Border Padding="9,3"
                                        CornerRadius="6"
                                        Background="#33FFFFFF"
                                        BorderBrush="#66FFFFFF"
                                        BorderThickness="1"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding IsAnnouncementCountdownVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Foreground="{Binding OnlineAnnouncementForeground}"
                                               FontFamily="Segoe UI Emoji"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Text="{Binding AnnouncementCountdownText}" />
                                </Border>

                                <Button Width="31"
                                        Height="29"
                                        MinHeight="0"
                                        Margin="8,0,0,0"
                                        Padding="0"
                                        Content="×"
                                        FontSize="19"
                                        FontWeight="Bold"
                                        Foreground="{Binding OnlineAnnouncementForeground}"
                                        Background="#22FFFFFF"
                                        BorderBrush="#55FFFFFF"
                                        BorderThickness="1"
                                        Click="OnlineAnnouncementClose_Click"
                                        Visibility="{Binding IsAnnouncementCloseVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Column="2"
      HorizontalAlignment="Right"
      VerticalAlignment="Center">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- TRẠNG THÁI MÁY CHỦ THÔNG BÁO -->
                    <Border x:Name="serverStatusBadge"
            Grid.Column="0"
            Height="36"
            MinWidth="260"
            MaxWidth="420"
            CornerRadius="18"
            Padding="12,0"
            Background="#ECFDF5"
            BorderBrush="#22C55E"
            BorderThickness="1.5"
            VerticalAlignment="Center">

                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10"
                              ShadowDepth="0"
                              Opacity="0.16"/>
                        </Border.Effect>

                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid Width="14"
                  Height="14"
                  VerticalAlignment="Center">

                                <Ellipse x:Name="serverStatusGlow"
                         Fill="#22C55E"
                         Opacity="0.22"/>

                                <Ellipse x:Name="serverStatusDot"
                         Width="9"
                         Height="9"
                         Fill="#22C55E"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
                            </Grid>

                            <TextBlock x:Name="txtUpdateStatus"
                       Grid.Column="2"
                       Text="Đang kiểm tra máy chủ thông báo..."
                       Foreground="#166534"
                       FontSize="13"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis"
                       MaxWidth="370"/>
                        </Grid>
                    </Border>

                    <!-- NÚT CẬP NHẬT: MẶC ĐỊNH ẨN -->
                    <Grid x:Name="softwareUpdatePanel"
          Grid.Column="2"
          Visibility="Collapsed">

                        <Button x:Name="btnSoftwareUpdate"
                Height="36"
                MinWidth="150"
                Padding="14,0"
                Content="CẬP NHẬT"
                Click="SoftwareUpdate_Click"
                IsEnabled="False"
                FontSize="13"
                FontWeight="ExtraBold"
                Foreground="White"
                Background="#DC2626"
                BorderBrush="#991B1B"
                BorderThickness="1"
                Cursor="Hand">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="18"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Ellipse x:Name="updateNotificationDot"
                 Width="10"
                 Height="10"
                 Fill="#FDE047"
                 Stroke="White"
                 StrokeThickness="1.5"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Top"
                 Visibility="Collapsed"/>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" SelectedIndex="{Binding TabControlSelectedIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.ColumnSpan="2" Margin="0,4,0,0">
            <TabItem Header="QUÉT TEM">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <!-- Industrial compact responsive layout: left compact, ScanHistory flexible, TodayBox wide but no overflow -->
                        <ColumnDefinition Width="280" MinWidth="260" MaxWidth="300"/>
                        <ColumnDefinition Width="*" MinWidth="0"/>
                        <ColumnDefinition Width="520" MinWidth="500" MaxWidth="540"/>
                    </Grid.ColumnDefinitions>

                    <!-- DASHBOARD THỐNG KÊ NHANH TRONG NGÀY -->
                    <Grid Grid.Row="0" Grid.ColumnSpan="3" Margin="4,0,4,10" Height="82">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <materialDesign:Card Grid.Column="0" Margin="0,0,8,0" Padding="10" UniformCornerRadius="12" Background="White">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="TODAY SCAN" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                                <TextBlock Grid.Row="1" Text="{Binding TodayScanCount}" FontSize="26" FontWeight="Black" Foreground="#0F172A" VerticalAlignment="Center"/>
                            </Grid>
                        </materialDesign:Card>

                        <materialDesign:Card Grid.Column="1" Margin="0,0,8,0" Padding="10" UniformCornerRadius="12" Background="#ECFDF5">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="PASS" FontSize="11" FontWeight="Bold" Foreground="#047857"/>
                                <TextBlock Grid.Row="1" Text="{Binding TodayPassCount}" FontSize="26" FontWeight="Black" Foreground="#059669" VerticalAlignment="Center"/>
                            </Grid>
                        </materialDesign:Card>

                        <materialDesign:Card Grid.Column="2" Margin="0,0,8,0" Padding="10" UniformCornerRadius="12" Background="#FEF2F2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="FAIL" FontSize="11" FontWeight="Bold" Foreground="#B91C1C"/>
                                <TextBlock Grid.Row="1" Text="{Binding TodayFailCount}" FontSize="26" FontWeight="Black" Foreground="#DC2626" VerticalAlignment="Center"/>
                            </Grid>
                        </materialDesign:Card>

                        <materialDesign:Card Grid.Column="3" Margin="0,0,8,0" Padding="10" UniformCornerRadius="12" Background="#EFF6FF">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="HIỆU SUẤT" FontSize="11" FontWeight="Bold" Foreground="#1D4ED8"/>
                                <TextBlock Grid.Row="1" Text="{Binding TodayYieldText}" FontSize="25" FontWeight="Black" Foreground="#2563EB" VerticalAlignment="Center"/>
                            </Grid>
                        </materialDesign:Card>

                        <materialDesign:Card Grid.Column="4" Margin="0,0,8,0" Padding="10" UniformCornerRadius="12" Background="#F8FAFC">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="TỔNG THÙNG" FontSize="11" FontWeight="Bold" Foreground="#475569"/>
                                <TextBlock Grid.Row="1" Text="{Binding TodayTotalBoxCount}" FontSize="26" FontWeight="Black" Foreground="#334155" VerticalAlignment="Center"/>
                            </Grid>
                        </materialDesign:Card>

                        <materialDesign:Card Grid.Column="5" Margin="0,0,8,0" Padding="10" UniformCornerRadius="12" Background="#F0FDF4">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="THÙNG ĐỦ" FontSize="11" FontWeight="Bold" Foreground="#047857"/>
                                <TextBlock Grid.Row="1" Text="{Binding TodayFullBoxCount}" FontSize="26" FontWeight="Black" Foreground="#059669" VerticalAlignment="Center"/>
                            </Grid>
                        </materialDesign:Card>

                        <materialDesign:Card Grid.Column="6" Margin="0" Padding="10" UniformCornerRadius="12" Background="#FFF7ED">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="THÙNG LẺ" FontSize="11" FontWeight="Bold" Foreground="#C2410C"/>
                                <TextBlock Grid.Row="1" Text="{Binding TodayPartialBoxCount}" FontSize="26" FontWeight="Black" Foreground="#F97316" VerticalAlignment="Center"/>
                            </Grid>
                        </materialDesign:Card>
                    </Grid>

                    <Grid Grid.Row="1" Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <materialDesign:Card Margin="4"
                                             Padding="0"
                                             UniformCornerRadius="14"
                                             Background="White">
                            <Border CornerRadius="14"
                                    Background="White"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1">
                                <Grid Margin="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid.Resources>
                                        <Style x:Key="InfoLabelStyle" TargetType="TextBlock">
                                            <Setter Property="FontSize" Value="10"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="#64748B"/>
                                            <Setter Property="Margin" Value="0,0,0,3"/>
                                        </Style>

                                        <Style x:Key="InfoValueStyle" TargetType="TextBlock">
                                            <Setter Property="FontSize" Value="13"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="#0F172A"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        </Style>
                                    </Grid.Resources>

                                    <!-- HEADER THÔNG TIN BOX -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Width="5"
                                                    Height="18"
                                                    CornerRadius="4"
                                                    Background="#2563EB"
                                                    Margin="0,0,7,0"/>
                                            <TextBlock Text="THÔNG TIN BOX"
                                                       FontSize="13"
                                                       FontWeight="Black"
                                                       Foreground="#0F172A"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <Border Grid.Column="1"
                                                CornerRadius="999"
                                                Padding="8,3"
                                                Background="{Binding CurrentBoxStatusBackground}"
                                                BorderBrush="{Binding CurrentBoxStatusBorderBrush}"
                                                BorderThickness="1"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding CurrentBoxStatusText}"
                                                       FontSize="10.5"
                                                       FontWeight="Bold"
                                                       Foreground="{Binding CurrentBoxStatusForeground}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                    </Grid>

                                    <!-- PRODUCT SELECTOR: KHÔNG BỊ BÓP KHI START -->
                                    <Border Grid.Row="2"
                                            CornerRadius="10"
                                            Background="#F8FAFC"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            Padding="8,6">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                                                       Text="MÃ HÀNG / NAME"
                                                       Style="{StaticResource InfoLabelStyle}"/>

                                            <ComboBox Grid.Row="1"
                                                      MinWidth="0"
                                                      Height="31"
                                                      FontSize="13"
                                                      FontWeight="SemiBold"
                                                      HorizontalAlignment="Stretch"
                                                      ItemsSource="{Binding PartNumberList}"
                                                      SelectedItem="{Binding SelectedPartNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      IsEnabled="{Binding CanSwitchProduct}" />
                                        </Grid>
                                    </Border>

                                    <!-- FORM DATE / QTY / STATUS: CHIA CARD NHỎ GỌN -->
                                    <UniformGrid Grid.Row="4"
