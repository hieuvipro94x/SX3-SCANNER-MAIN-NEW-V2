<Window x:Class="SX3_SCANER.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SX3_SCANER"
        xmlns:controls="clr-namespace:SX3_SCANER.Views.Controls"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:viewmodel="clr-namespace:SX3_SCANER.ViewModel"
        d:DataContext="{d:DesignInstance Type=viewmodel:MainViewModel}"
        Style="{StaticResource MaterialDesignWindow}"
        mc:Ignorable="d"
        Title="SX3 Scanner"
        Height="700"
        Width="1180"
        MinHeight="540"
        MinWidth="920"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="CanResize"
        SizeToContent="Manual"
        FontFamily="Segoe UI"
        Background="#F8FAFC"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="69*"/>
            <ColumnDefinition Width="571*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="White"
                BorderBrush="#E0E7EF"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="1"
                      x:Name="topAnnouncementArea"
                      Margin="8,0,14,0"
                      HorizontalAlignment="Stretch">
                    <Border x:Name="onlineAnnouncementHost"
                             Width="{Binding ActualWidth, ElementName=topAnnouncementArea}"
                             MinWidth="760"
                             MaxWidth="1300"
                            Height="42"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            CornerRadius="11"
                            Padding="12,4"
                            BorderThickness="2"
                            Background="{Binding OnlineAnnouncementBackground}"
                            BorderBrush="{Binding OnlineAnnouncementBorderBrush}">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12"
                                              ShadowDepth="0"
                                              Opacity="0.35" />
                        </Border.Effect>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOnlineAnnouncementVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Grid ClipToBounds="True"
                              VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="38" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding OnlineAnnouncementIcon}"
                                       Foreground="{Binding OnlineAnnouncementForeground}"
                                       FontFamily="Segoe UI Emoji"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />

                            <TextBlock Grid.Column="1"
                                       Margin="6,0,12,0"
                                       Text="{Binding OnlineAnnouncementTitle, StringFormat={}{0}:}"
                                       Foreground="{Binding OnlineAnnouncementForeground}"
                                       FontFamily="Segoe UI"
                                       FontSize="14"
                                       FontWeight="ExtraBold"
                                       VerticalAlignment="Center"
                                       TextWrapping="NoWrap" />

                            <Canvas Grid.Column="2"
                                    x:Name="AnnouncementMarqueeHost"
                                    Margin="0,0,8,0"
                                    ClipToBounds="True"
                                    VerticalAlignment="Stretch">
                                <TextBlock x:Name="AnnouncementMarqueeText"
                                           Text="{Binding OnlineAnnouncementText}"
                                           Canvas.Top="6"
                                           FontFamily="Segoe UI"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{Binding OnlineAnnouncementForeground}"
                                           TextWrapping="NoWrap">
                                    <TextBlock.RenderTransform>
                                        <TranslateTransform x:Name="AnnouncementMarqueeTransform" />
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Canvas>

                            <StackPanel Grid.Column="3"
                                        Margin="6,0,0,0"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Border Padding="9,3"
                                        CornerRadius="6"
                                        Background="#33FFFFFF"
                                        BorderBrush="#66FFFFFF"
                                        BorderThickness="1"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding IsAnnouncementCountdownVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Foreground="{Binding OnlineAnnouncementForeground}"
                                               FontFamily="Segoe UI Emoji"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Text="{Binding AnnouncementCountdownText}" />
                                </Border>

                                <Button Width="31"
                                        Height="29"
                                        MinHeight="0"
                                        Margin="8,0,0,0"
                                        Padding="0"
                                        Content="×"
                                        FontSize="19"
                                        FontWeight="Bold"
                                        Foreground="{Binding OnlineAnnouncementForeground}"
                                        Background="#22FFFFFF"
                                        BorderBrush="#55FFFFFF"
                                        BorderThickness="1"
                                        Click="OnlineAnnouncementClose_Click"
                                        Visibility="{Binding IsAnnouncementCloseVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Column="2"
      HorizontalAlignment="Right"
      VerticalAlignment="Center">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- TRẠNG THÁI MÁY CHỦ THÔNG BÁO -->
                    <Border x:Name="serverStatusBadge"
            Grid.Column="0"
            Height="36"
            MinWidth="260"
            MaxWidth="420"
            CornerRadius="18"
            Padding="12,0"
            Background="#ECFDF5"
            BorderBrush="#22C55E"
            BorderThickness="1.5"
            VerticalAlignment="Center">

                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10"
                              ShadowDepth="0"
                              Opacity="0.16"/>
                        </Border.Effect>

                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid Width="14"
                  Height="14"
                  VerticalAlignment="Center">

                                <Ellipse x:Name="serverStatusGlow"
                         Fill="#22C55E"
                         Opacity="0.22"/>

                                <Ellipse x:Name="serverStatusDot"
                         Width="9"
                         Height="9"
                         Fill="#22C55E"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
                            </Grid>

                            <TextBlock x:Name="txtUpdateStatus"
                       Grid.Column="2"
                       Text="Đang kiểm tra máy chủ thông báo..."
                       Foreground="#166534"
                       FontSize="13"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis"
                       MaxWidth="370"/>
                        </Grid>
                    </Border>

                    <!-- NÚT CẬP NHẬT: MẶC ĐỊNH ẨN -->
                    <Grid x:Name="softwareUpdatePanel"
          Grid.Column="2"
          Visibility="Collapsed">

                        <Button x:Name="btnSoftwareUpdate"
                Height="36"
                MinWidth="150"
                Padding="14,0"
                Content="CẬP NHẬT"
                Click="SoftwareUpdate_Click"
                IsEnabled="False"
                FontSize="13"
                FontWeight="ExtraBold"
                Foreground="White"
                Background="#DC2626"
                BorderBrush="#991B1B"
                BorderThickness="1"
                Cursor="Hand">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="18"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Ellipse x:Name="updateNotificationDot"
                 Width="10"
                 Height="10"
                 Fill="#FDE047"
                 Stroke="White"
                 StrokeThickness="1.5"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Top"
                 Visibility="Collapsed"/>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <TabControl Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="0"
                    Style="{StaticResource ProfessionalMainTabControlStyle}"
                    ItemContainerStyle="{StaticResource ProfessionalMainTabItemStyle}"
                    SelectedIndex="{Binding TabControlSelectedIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <TabItem Header="QUÉT TEM">
                <controls:ScanTabView />
            </TabItem>
            <TabItem Header="CẤU HÌNH CHUNG">
                <controls:ProductConfigTab />
            </TabItem>
            <TabItem Header="TÌM KIẾM LỊCH SỬ SCAN">
                <controls:HistorySearchTab />
            </TabItem>
        </TabControl>

        <Border Grid.Row="2"
                Grid.ColumnSpan="2"
                Background="#E2E8F0"
                BorderBrush="#CBD5E1"
                BorderThickness="0,1,0,0"
                Padding="16,4,16,5">
            <Grid>
                <TextBlock x:Name="txtStartupStatus"
                           Margin="0"
                           Text="Sẵn sàng"
                           FontSize="18"
                           FontWeight="ExtraBold"
                           Foreground="Green"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           TextWrapping="NoWrap"
                           TextTrimming="None" />
            </Grid>
        </Border>

    </Grid>
</Window>
