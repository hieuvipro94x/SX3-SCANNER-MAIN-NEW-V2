                           FontWeight="Bold"
                           Foreground="#16A34A"
                           HorizontalAlignment="Center"/>

                                            <TextBlock Grid.Column="3"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           FontSize="15">

                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">

                                                        <Style.Triggers>

                                                            <DataTrigger Binding="{Binding Length_OK}" Value="1">
                                                                <Setter Property="Text" Value="OK"/>
                                                                <Setter Property="Foreground" Value="#16A34A"/>
                                                            </DataTrigger>

                                                            <DataTrigger Binding="{Binding Length_OK}" Value="0">
