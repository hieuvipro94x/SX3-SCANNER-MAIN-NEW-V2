                                                                            <DataTrigger Binding="{Binding BtnSTART_CONTENT}" Value="DỪNG">
                                                                                <Setter Property="Kind" Value="StopCircle"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </materialDesign:PackIcon.Style>
                                                            </materialDesign:PackIcon>

                                                            <TextBlock Text="{Binding BtnSTART_CONTENT}"
                                                                       Margin="0,2,0,0"
                                                                       FontSize="12"
                                                                       FontWeight="Bold"
                                                                       Foreground="White"
                                                                       TextAlignment="Center"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
