                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- RESULT -->
                            <Border x:Name="ScanResultBorder"
                                    Grid.Row="0"
                                    CornerRadius="22"
                                    Padding="20,18"
                                    Margin="12,10,12,12"
                                    Background="{Binding ResultBackgroundBrush}"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    MinHeight="220"
                                    Opacity="1"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <Border.Effect>
                                    <DropShadowEffect Color="#334155"
                                                      BlurRadius="24"
                                                      ShadowDepth="4"
                                                      Direction="270"
                                                      Opacity="0.28"/>
                                </Border.Effect>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ScanTextResult}" Value="OK">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
