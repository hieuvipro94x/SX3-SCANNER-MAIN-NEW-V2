<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:SX3_SCANER"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB" />
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#1D4ED8" />
    <SolidColorBrush x:Key="TextMainBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#64748B" />
    <SolidColorBrush x:Key="InputBgBrush" Color="#FAFBFD" />
    <SolidColorBrush x:Key="OkBrush" Color="#16A34A" />
    <SolidColorBrush x:Key="NgBrush" Color="#DC2626" />
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

    <Style TargetType="materialDesign:Card">
        <Setter Property="Background" Value="{StaticResource PanelBrush}" />
        <Setter Property="UniformCornerRadius" Value="12" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="Margin" Value="6" />
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Margin" Value="3" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Background" Value="{StaticResource InputBgBrush}" />
        <Setter Property="BorderBrush" Value="#CBD5E1" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Margin" Value="3" />
        <Setter Property="Padding" Value="6,3" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Background" Value="{StaticResource InputBgBrush}" />
        <Setter Property="BorderBrush" Value="#CBD5E1" />
    </Style>

    <Style TargetType="DatePicker">
        <Setter Property="Margin" Value="3" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Background" Value="{StaticResource InputBgBrush}" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Margin" Value="4" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryDarkBrush}" />
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="Margin" Value="4" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="#E0E7EF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="RowHeight" Value="32" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="AlternatingRowBackground" Value="#F8FAFC" />
        <Setter Property="HorizontalGridLinesBrush" Value="#E6EDF5" />
        <Setter Property="VerticalGridLinesBrush" Value="#E6EDF5" />
        <Setter Property="EnableRowVirtualization" Value="True" />
        <Setter Property="EnableColumnVirtualization" Value="True" />
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#F1F5F9" />
        <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Padding" Value="6,0" />
    </Style>

    <local:ScanRowBackgroundBrushConverter x:Key="ScanRowBackgroundBrushConverter"/>
    <local:ScanRowForegroundBrushConverter x:Key="ScanRowForegroundBrushConverter"/>

    <Style x:Key="UnifiedScanDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#F8FAFC"/>
        <Setter Property="Foreground" Value="#0F172A"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="Padding" Value="6,0"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="BorderBrush" Value="#E2E8F0"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
    </Style>

    <Style x:Key="UnifiedScanRowStyle" TargetType="DataGridRow">
        <Setter Property="Background" Value="{Binding Converter={StaticResource ScanRowBackgroundBrushConverter}}"/>
        <Setter Property="Foreground" Value="{Binding Converter={StaticResource ScanRowForegroundBrushConverter}}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#E0F2FE"/>
                <Setter Property="Foreground" Value="#0F172A"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#2563EB"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="TabControl">
        <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="16,8" />
    </Style>


    <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#1565C0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
    <Style x:Key="SubFieldLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource FieldLabelStyle}">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#90A4AE" />
        <Setter Property="Margin" Value="12,0,0,0" />
    </Style>
    <Style x:Key="ExpectedValueBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="#FFFDE7" />
        <Setter Property="BorderBrush" Value="#F1E9A8" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="MinHeight" Value="36" />
    </Style>
    <Style x:Key="ExpectedValueTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="#0D47A1" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
    <Style x:Key="ScanResultTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#16A34A" />
        <Setter Property="Background" Value="#F8FAFC" />
        <Setter Property="BorderBrush" Value="#E3EAF2" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="10,3" />
    </Style>
    <Style x:Key="StatusTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Width" Value="38" />
        <Setter Property="Height" Value="32" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>


    <!-- MAIN NAVIGATION - PROFESSIONAL TAB STYLE -->
    <Style x:Key="ProfessionalMainTabControlStyle" TargetType="{x:Type TabControl}">
        <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8,4,8,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabControl}">
                    <Grid KeyboardNavigation.TabNavigation="Local"
                      SnapsToDevicePixels="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Navigation bar -->
                        <Border Grid.Row="0"
                            Margin="8,8,8,0"
                            Padding="8,6"
                            Background="#FFFFFF"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="14">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14"
                                              ShadowDepth="0"
                                              Opacity="0.08"/>
                            </Border.Effect>

                            <DockPanel LastChildFill="True">
                                <Border DockPanel.Dock="Left"
                                    Width="4"
                                    Height="28"
                                    Margin="0,0,10,0"
                                    CornerRadius="2"
                                    Background="#2563EB"
                                    VerticalAlignment="Center"/>

                                <TabPanel x:Name="HeaderPanel"
                                      IsItemsHost="True"
                                      KeyboardNavigation.TabIndex="1"
                                      Panel.ZIndex="1"
                                      Background="Transparent"/>
                            </DockPanel>
                        </Border>

                        <!-- Selected tab content -->
                        <Border Grid.Row="1"
                            Background="{TemplateBinding Background}"
                            BorderThickness="0"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                          Margin="0,4,0,0"
                                          ContentSource="SelectedContent"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ProfessionalMainTabItemStyle" TargetType="{x:Type TabItem}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Foreground" Value="#475569"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="ExtraBold"/>
        <Setter Property="MinHeight" Value="38"/>
        <Setter Property="MinWidth" Value="128"/>
        <Setter Property="Margin" Value="2,0,4,0"/>
        <Setter Property="Padding" Value="18,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabItem}">
                    <Border x:Name="Root"
                        MinHeight="{TemplateBinding MinHeight}"
                        MinWidth="{TemplateBinding MinWidth}"
                        Margin="{TemplateBinding Margin}"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="11"
                        SnapsToDevicePixels="True">
                        <Grid>
                            <ContentPresenter x:Name="ContentSite"
                                          ContentSource="Header"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#EFF6FF"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="#BFDBFE"/>
                            <Setter Property="Foreground" Value="#1D4ED8"/>
                        </Trigger>

                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#2563EB"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="#1D4ED8"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#94A3B8"/>
                            <Setter TargetName="Root" Property="Opacity" Value="0.65"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
