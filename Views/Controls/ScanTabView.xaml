<UserControl x:Class="SX3_SCANER.Views.Controls.ScanTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:SX3_SCANER"
             xmlns:controls="clr-namespace:SX3_SCANER.Views.Controls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodel="clr-namespace:SX3_SCANER.ViewModel"
             d:DataContext="{d:DesignInstance Type=viewmodel:MainViewModel}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <!-- Layout tối ưu: mở rộng panel scan để không che/mất chữ khi scan -->
            <ColumnDefinition Width="330" MinWidth="310" MaxWidth="360"/>
            <ColumnDefinition Width="*" MinWidth="0"/>
            <ColumnDefinition Width="520" MinWidth="500" MaxWidth="540"/>
        </Grid.ColumnDefinitions>

        <controls:DashboardStatsPanel Grid.Row="0"
                                      Grid.ColumnSpan="3"/>

        <controls:ScanLeftPanel Grid.Row="1"
                                Grid.Column="0"/>

        <controls:ScanInputHistoryPanel Grid.Row="1"
                                        Grid.Column="1"/>

        <controls:ScanRightPanel Grid.Row="1"
                                 Grid.Column="2"/>
    </Grid>
</UserControl>
