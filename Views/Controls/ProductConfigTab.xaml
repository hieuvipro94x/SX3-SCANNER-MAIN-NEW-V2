<UserControl x:Class="SX3_SCANER.Views.Controls.ProductConfigTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:SX3_SCANER"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ===================== PRODUCT CONFIG PROFESSIONAL THEME ===================== -->
            <SolidColorBrush x:Key="ConfigPageBackground" Color="#F4F7FB" />
            <SolidColorBrush x:Key="ConfigCardBackground" Color="#FFFFFF" />
            <SolidColorBrush x:Key="ConfigSoftCardBackground" Color="#F8FAFC" />
            <SolidColorBrush x:Key="ConfigBorderBrush" Color="#E2E8F0" />
            <SolidColorBrush x:Key="ConfigMutedBorderBrush" Color="#CBD5E1" />
            <SolidColorBrush x:Key="ConfigTextMainBrush" Color="#0F172A" />
            <SolidColorBrush x:Key="ConfigTextMutedBrush" Color="#64748B" />
            <SolidColorBrush x:Key="ConfigPrimaryBrush" Color="#2563EB" />
            <SolidColorBrush x:Key="ConfigPrimaryDarkBrush" Color="#1D4ED8" />
            <SolidColorBrush x:Key="ConfigPrimarySoftBrush" Color="#EFF6FF" />
            <SolidColorBrush x:Key="ConfigDangerBrush" Color="#DC2626" />
            <SolidColorBrush x:Key="ConfigDangerDarkBrush" Color="#B91C1C" />
            <SolidColorBrush x:Key="ConfigDangerSoftBrush" Color="#FEF2F2" />
            <SolidColorBrush x:Key="ConfigSuccessBrush" Color="#16A34A" />
            <SolidColorBrush x:Key="ConfigSuccessDarkBrush" Color="#15803D" />
            <SolidColorBrush x:Key="ConfigSuccessSoftBrush" Color="#F0FDF4" />
            <SolidColorBrush x:Key="ConfigWarningBrush" Color="#F59E0B" />
            <SolidColorBrush x:Key="ConfigWarningDarkBrush" Color="#D97706" />
            <SolidColorBrush x:Key="ConfigWarningSoftBrush" Color="#FFFBEB" />
            <SolidColorBrush x:Key="ConfigInputFocusBrush" Color="#60A5FA" />
            <SolidColorBrush x:Key="ConfigReadOnlyBrush" Color="#F1F5F9" />

            <Style x:Key="ConfigCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource ConfigCardBackground}" />
                <Setter Property="BorderBrush" Value="{StaticResource ConfigBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="18" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="24"
                                          ShadowDepth="0"
                                          Opacity="0.10"
                                          Color="#334155" />
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ConfigMiniIconBoxStyle" TargetType="Border">
                <Setter Property="Width" Value="44" />
                <Setter Property="Height" Value="44" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Background" Value="{StaticResource ConfigPrimarySoftBrush}" />
                <Setter Property="BorderBrush" Value="#BFDBFE" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style x:Key="ConfigPageTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ConfigTextMainBrush}" />
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontWeight" Value="Black" />
                <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
                <Setter Property="LineHeight" Value="24" />
            </Style>

            <Style x:Key="ConfigSectionTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ConfigTextMainBrush}" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontWeight" Value="Black" />
                <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
                <Setter Property="LineHeight" Value="20" />
            </Style>

            <Style x:Key="ConfigSubTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ConfigTextMutedBrush}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="LineHeight" Value="17" />
            </Style>

            <Style x:Key="ConfigFieldLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#334155" />
                <Setter Property="FontSize" Value="11.5" />
                <Setter Property="FontWeight" Value="Black" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="Margin" Value="0,0,10,0" />
            </Style>

            <Style x:Key="ConfigHintTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ConfigTextMutedBrush}" />
                <Setter Property="FontSize" Value="10.5" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="ConfigTextBoxStyle" TargetType="TextBox">
                <Setter Property="Height" Value="40" />
                <Setter Property="MinHeight" Value="40" />
                <Setter Property="FontSize" Value="13.5" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource ConfigTextMainBrush}" />
                <Setter Property="Background" Value="#F8FAFC" />
                <Setter Property="BorderBrush" Value="{StaticResource ConfigMutedBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="12,0" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="TextAlignment" Value="Left" />
                <Setter Property="Margin" Value="0,4" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="CaretBrush" Value="{StaticResource ConfigPrimaryBrush}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="InputBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="11"
                                    SnapsToDevicePixels="True">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              HorizontalAlignment="Stretch" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource ConfigInputFocusBrush}" />
                                    <Setter TargetName="InputBorder" Property="BorderThickness" Value="2" />
                                    <Setter TargetName="InputBorder" Property="Background" Value="White" />
                                </Trigger>
                                <Trigger Property="IsReadOnly" Value="True">
                                    <Setter TargetName="InputBorder" Property="Background" Value="{StaticResource ConfigReadOnlyBrush}" />
                                    <Setter Property="Foreground" Value="{StaticResource ConfigTextMutedBrush}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="InputBorder" Property="Opacity" Value="0.55" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ConfigSearchTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource ConfigTextBoxStyle}">
                <Setter Property="Height" Value="42" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="0,0,12,0" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ConfigButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="42" />
                <Setter Property="MinWidth" Value="98" />
                <Setter Property="Padding" Value="14,0" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Background" Value="{StaticResource ConfigPrimaryBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ConfigPrimaryDarkBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="FontSize" Value="12.5" />
                <Setter Property="FontWeight" Value="Black" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ButtonBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="12"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.78" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ConfigGhostButtonStyle" TargetType="Button" BasedOn="{StaticResource ConfigButtonStyle}">
                <Setter Property="Foreground" Value="{StaticResource ConfigPrimaryBrush}" />
                <Setter Property="Background" Value="{StaticResource ConfigPrimarySoftBrush}" />
                <Setter Property="BorderBrush" Value="#BFDBFE" />
            </Style>

            <Style x:Key="ConfigDataGridTextStyle" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="TextAlignment" Value="Center" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="Padding" Value="8,0" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}" />
            </Style>

            <Style x:Key="ConfigDataGridLeftTextStyle" TargetType="TextBlock" BasedOn="{StaticResource ConfigDataGridTextStyle}">
                <Setter Property="TextAlignment" Value="Left" />
            </Style>

            <Style x:Key="ConfigColumnHeaderStyle" TargetType="DataGridColumnHeader">
                <Setter Property="Height" Value="42" />
                <Setter Property="Background" Value="#F1F5F9" />
                <Setter Property="Foreground" Value="#334155" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontWeight" Value="Black" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Padding" Value="8,0" />
                <Setter Property="BorderBrush" Value="#E2E8F0" />
                <Setter Property="BorderThickness" Value="0,0,1,1" />
            </Style>

            <Style x:Key="ConfigCellStyle" TargetType="DataGridCell">
                <Setter Property="Padding" Value="6,0" />
                <Setter Property="BorderBrush" Value="#F1F5F9" />
                <Setter Property="BorderThickness" Value="0,0,1,1" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource ConfigTextMainBrush}" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#DBEAFE" />
                        <Setter Property="Foreground" Value="#1E3A8A" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ConfigRowStyle" TargetType="DataGridRow">
                <Setter Property="Background" Value="White" />
                <Setter Property="Foreground" Value="{StaticResource ConfigTextMainBrush}" />
                <Setter Property="FontSize" Value="12.5" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Style.Triggers>
                    <Trigger Property="AlternationIndex" Value="1">
                        <Setter Property="Background" Value="#F8FAFC" />
                    </Trigger>
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="IsMouseOver" Value="True" />
                            <Condition Property="IsSelected" Value="False" />
                        </MultiTrigger.Conditions>
                        <Setter Property="Background" Value="#EFF6FF" />
                    </MultiTrigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#DBEAFE" />
                        <Setter Property="Foreground" Value="#1E3A8A" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{StaticResource ConfigPageBackground}" Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="450" MinWidth="410" MaxWidth="490" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" MinWidth="650" />
        </Grid.ColumnDefinitions>

        <!-- ===================== LEFT: PRODUCT FORM ===================== -->
        <Border Grid.Column="0" Style="{StaticResource ConfigCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource ConfigMiniIconBoxStyle}">
                        <materialDesign:PackIcon Kind="Tune"
                                                 Width="23"
                                                 Height="23"
                                                 Foreground="{StaticResource ConfigPrimaryBrush}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                    </Border>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="THÔNG TIN MÃ HÀNG"
                                   Style="{StaticResource ConfigPageTitleStyle}" />
                        <TextBlock Text="Cấu hình định dạng mã QR, độ dài và số lượng đóng thùng."
                                   Style="{StaticResource ConfigSubTitleStyle}"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="2"
                        CornerRadius="12"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        Padding="12,9">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="8" Height="8" Fill="{StaticResource ConfigPrimaryBrush}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="Chọn một dòng trong bảng bên phải để sửa nhanh thông tin cấu hình."
                                   Style="{StaticResource ConfigHintTextStyle}"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- Form content -->
                <ScrollViewer Grid.Row="4"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False">
                    <Grid Margin="0,0,4,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="104" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="ID" Style="{StaticResource ConfigFieldLabelStyle}" />
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Text="{Binding CURR_ID}"
                                 IsReadOnly="True"
                                 Style="{StaticResource ConfigTextBoxStyle}"
                                 d:Text="1001" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="CAR" Style="{StaticResource ConfigFieldLabelStyle}" />
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Text="{Binding CURR_CAR, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ConfigTextBoxStyle}"
                                 d:Text="SX3" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="PART NO" Style="{StaticResource ConfigFieldLabelStyle}" />
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{Binding CURR_PARTNUMBER, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ConfigTextBoxStyle}"
                                 d:Text="N6375-001" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="PART NAME" Style="{StaticResource ConfigFieldLabelStyle}" />
                        <TextBox Grid.Row="3" Grid.Column="1"
                                 Text="{Binding CURR_PARTNAME, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ConfigTextBoxStyle}"
                                 d:Text="PART NAME SAMPLE" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="PREFIX" Style="{StaticResource ConfigFieldLabelStyle}" />
                        <TextBox Grid.Row="4" Grid.Column="1"
                                 Text="{Binding CURR_PREFIX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ConfigTextBoxStyle}"
                                 d:Text="ABC" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="SUFFIX" Style="{StaticResource ConfigFieldLabelStyle}" />
                        <TextBox Grid.Row="5" Grid.Column="1"
                                 Text="{Binding CURR_SUFFIX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ConfigTextBoxStyle}"
                                 d:Text="XYZ" />

                        <TextBlock Grid.Row="6"
                                   Grid.Column="0"
                                   Text="SAMPLE"
                                   Style="{StaticResource ConfigFieldLabelStyle}"
                                   VerticalAlignment="Top"
                                   Margin="0,14,10,0" />
                        <TextBox Grid.Row="6" Grid.Column="1"
                                 Text="{Binding CURR_SAMPLE}"
                                 Style="{StaticResource ConfigTextBoxStyle}"
                                 Height="84"
                                 MinHeight="84"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 VerticalContentAlignment="Top"
                                 Padding="12,10"
                                 d:Text="THISISATEXTBOXTHISISATEXTBOXTHISISATEXTBOX" />

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="LENGTH" Style="{StaticResource ConfigFieldLabelStyle}" />
                        <TextBox Grid.Row="7" Grid.Column="1"
                                 Text="{Binding CURR_LENGTH, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ConfigTextBoxStyle}"
                                 d:Text="20" />

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="BOX QTY" Style="{StaticResource ConfigFieldLabelStyle}" />
                        <TextBox Grid.Row="8" Grid.Column="1"
                                 Text="{Binding CURR_QTY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ConfigTextBoxStyle}"
                                 d:Text="20" />
                    </Grid>
                </ScrollViewer>

                <!-- Actions -->
                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="9" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="9" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource ConfigButtonStyle}"
                            Background="{StaticResource ConfigDangerBrush}"
                            BorderBrush="{StaticResource ConfigDangerDarkBrush}"
                            Command="{Binding DELETECMD}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="Delete"
                                                     Width="18"
                                                     Height="18"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,6,0" />
                            <TextBlock Text="XÓA" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2"
                            Style="{StaticResource ConfigButtonStyle}"
                            Background="{StaticResource ConfigSuccessBrush}"
                            BorderBrush="{StaticResource ConfigSuccessDarkBrush}"
                            Command="{Binding ADDCMD}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="Plus"
                                                     Width="18"
                                                     Height="18"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,6,0" />
                            <TextBlock Text="THÊM" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="4"
                            Style="{StaticResource ConfigButtonStyle}"
                            Background="{StaticResource ConfigWarningBrush}"
                            BorderBrush="{StaticResource ConfigWarningDarkBrush}"
                            Command="{Binding MODIFYCMD}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="Pencil"
                                                     Width="18"
                                                     Height="18"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,6,0" />
                            <TextBlock Text="SỬA" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <!-- ===================== RIGHT: SEARCH + TABLE ===================== -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Search card -->
            <Border Grid.Row="0" Style="{StaticResource ConfigCardStyle}" Padding="16,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="430" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource ConfigMiniIconBoxStyle}"
                            Background="#EEF2FF"
                            BorderBrush="#C7D2FE">
                        <materialDesign:PackIcon Kind="FormatListBulleted"
                                                 Width="23"
                                                 Height="23"
                                                 Foreground="{StaticResource ConfigPrimaryBrush}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                    </Border>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="DANH SÁCH CẤU HÌNH"
                                   Style="{StaticResource ConfigSectionTitleStyle}" />
                        <TextBlock Text="Tìm theo Car, Part Number, Part Name, Prefix hoặc Suffix rồi chọn dòng để sửa."
                                   Style="{StaticResource ConfigSubTitleStyle}"
                                   Margin="0,2,0,0" />
                    </StackPanel>

                    <Grid Grid.Column="4" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="106" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#F8FAFC"
                                BorderBrush="#CBD5E1"
                                BorderThickness="1"
                                CornerRadius="12"
                                Height="42">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="42" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Grid.Column="0"
                                                         Kind="Magnify"
                                                         Width="19"
                                                         Height="19"
                                                         Foreground="#64748B"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding InputProductNameSearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=220}"
                                         Style="{StaticResource ConfigSearchTextBoxStyle}"
                                         ToolTip="Tìm theo Car / Part Number / Part Name / Prefix / Suffix"
                                         d:Text="Nhập PartName cần tìm" />
                            </Grid>
                        </Border>

                        <Button Grid.Column="2"
                                Style="{StaticResource ConfigButtonStyle}"
                                Height="42"
                                MinWidth="106"
                                Background="{StaticResource ConfigPrimaryBrush}"
                                BorderBrush="{StaticResource ConfigPrimaryDarkBrush}"
                                Command="{Binding SeachProductInfoCMD}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Search"
                                                         Width="18"
                                                         Height="18"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,7,0" />
                                <TextBlock Text="TÌM" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <!-- Table card -->
            <Border Grid.Row="2" Style="{StaticResource ConfigCardStyle}" Padding="0" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="54" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="4" Height="20" CornerRadius="2" Background="{StaticResource ConfigPrimaryBrush}" Margin="0,0,9,0" />
                            <TextBlock Text="BẢNG DỮ LIỆU MÃ HÀNG"
                                       Style="{StaticResource ConfigSectionTitleStyle}"
                                       FontSize="13.5"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Padding="10,5"
                                CornerRadius="10"
                                Background="#F1F5F9"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding LabelProductInfoView.Count, StringFormat={}{0:N0} dòng}"
                                       FontSize="11"
                                       FontWeight="Black"
                                       Foreground="#475569" />
                        </Border>
                    </Grid>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding LabelProductInfoView}"
                              SelectedItem="{Binding SelectedProductInfoToModify, Mode=OneWayToSource}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              FontSize="12.5"
                              RowHeight="38"
                              ColumnHeaderHeight="42"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              CanUserResizeRows="False"
                              CanUserResizeColumns="False"
                              CanUserSortColumns="False"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              BorderThickness="1,1,0,0"
                              BorderBrush="#E2E8F0"
                              Background="White"
                              RowBackground="White"
                              AlternatingRowBackground="#F8FAFC"
                              HorizontalGridLinesBrush="#E2E8F0"
                              VerticalGridLinesBrush="#F1F5F9"
                              AlternationCount="2"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ColumnHeaderStyle="{StaticResource ConfigColumnHeaderStyle}"
                              CellStyle="{StaticResource ConfigCellStyle}"
                              RowStyle="{StaticResource ConfigRowStyle}">

                        <DataGrid.Resources>
                            <Style TargetType="ScrollBar">
                                <Setter Property="MinWidth" Value="10" />
                                <Setter Property="MinHeight" Value="10" />
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding ID}"
                                                Width="64"
                                                ElementStyle="{StaticResource ConfigDataGridTextStyle}" />

                            <DataGridTextColumn Header="CAR"
                                                Binding="{Binding Car}"
                                                Width="90"
                                                ElementStyle="{StaticResource ConfigDataGridTextStyle}" />

                            <DataGridTextColumn Header="PART NUMBER"
                                                Binding="{Binding PartNumber}"
                                                Width="150"
                                                ElementStyle="{StaticResource ConfigDataGridTextStyle}" />

                            <DataGridTextColumn Header="PART NAME"
                                                Binding="{Binding PartName}"
                                                Width="190"
                                                ElementStyle="{StaticResource ConfigDataGridLeftTextStyle}" />

                            <DataGridTextColumn Header="CODE FORMAT"
                                                Binding="{Binding CodeStringForm}"
                                                Width="270"
                                                ElementStyle="{StaticResource ConfigDataGridLeftTextStyle}" />

                            <DataGridTextColumn Header="PREFIX"
                                                Binding="{Binding CodePrefix}"
                                                Width="92"
                                                ElementStyle="{StaticResource ConfigDataGridTextStyle}" />

                            <DataGridTextColumn Header="SUFFIX"
                                                Binding="{Binding CodeSuffix}"
                                                Width="92"
                                                ElementStyle="{StaticResource ConfigDataGridTextStyle}" />

                            <DataGridTextColumn Header="LENGTH"
                                                Binding="{Binding CodeLength}"
                                                Width="88"
                                                ElementStyle="{StaticResource ConfigDataGridTextStyle}" />

                            <DataGridTextColumn Header="QTY"
                                                Binding="{Binding BoxQuantity}"
                                                Width="78"
                                                ElementStyle="{StaticResource ConfigDataGridTextStyle}" />

                            <DataGridTemplateColumn Header="VALID" Width="92">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border x:Name="ValidBadge"
                                                Padding="8,3"
                                                CornerRadius="9"
                                                Background="#F1F5F9"
                                                BorderBrush="#E2E8F0"
                                                BorderThickness="1"
                                                HorizontalAlignment="Center">
                                            <TextBlock x:Name="ValidText"
                                                       Text="N/A"
                                                       FontSize="10.5"
                                                       FontWeight="Black"
                                                       Foreground="#64748B" />
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsValid}" Value="True">
                                                <Setter TargetName="ValidBadge" Property="Background" Value="#DCFCE7" />
                                                <Setter TargetName="ValidBadge" Property="BorderBrush" Value="#BBF7D0" />
                                                <Setter TargetName="ValidText" Property="Text" Value="VALID" />
                                                <Setter TargetName="ValidText" Property="Foreground" Value="#15803D" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsValid}" Value="False">
                                                <Setter TargetName="ValidBadge" Property="Background" Value="#FEE2E2" />
                                                <Setter TargetName="ValidBadge" Property="BorderBrush" Value="#FECACA" />
                                                <Setter TargetName="ValidText" Property="Text" Value="INVALID" />
                                                <Setter TargetName="ValidText" Property="Foreground" Value="#B91C1C" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
