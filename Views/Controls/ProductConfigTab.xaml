<UserControl x:Class="SX3_SCANER.Views.Controls.ProductConfigTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:SX3_SCANER"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodel="clr-namespace:SX3_SCANER.ViewModel"
             d:DataContext="{d:DesignInstance Type=viewmodel:MainViewModel}"
             mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ===================== LOCAL PROFESSIONAL STYLES ===================== -->
            <SolidColorBrush x:Key="ConfigPageBackground" Color="#F3F6FA" />
            <SolidColorBrush x:Key="ConfigCardBackground" Color="#FFFFFF" />
            <SolidColorBrush x:Key="ConfigBorderBrush" Color="#E2E8F0" />
            <SolidColorBrush x:Key="ConfigMutedTextBrush" Color="#64748B" />
            <SolidColorBrush x:Key="ConfigTitleBrush" Color="#0F172A" />
            <SolidColorBrush x:Key="ConfigPrimaryBrush" Color="#2563EB" />
            <SolidColorBrush x:Key="ConfigPrimaryHoverBrush" Color="#1D4ED8" />
            <SolidColorBrush x:Key="ConfigDangerBrush" Color="#DC2626" />
            <SolidColorBrush x:Key="ConfigDangerHoverBrush" Color="#B91C1C" />
            <SolidColorBrush x:Key="ConfigSuccessBrush" Color="#16A34A" />
            <SolidColorBrush x:Key="ConfigSuccessHoverBrush" Color="#15803D" />
            <SolidColorBrush x:Key="ConfigWarningBrush" Color="#F59E0B" />
            <SolidColorBrush x:Key="ConfigWarningHoverBrush" Color="#D97706" />
            <SolidColorBrush x:Key="ConfigReadonlyBrush" Color="#F8FAFC" />
            <SolidColorBrush x:Key="ConfigInputFocusBrush" Color="#93C5FD" />

            <Style x:Key="ConfigCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource ConfigCardBackground}" />
                <Setter Property="BorderBrush" Value="{StaticResource ConfigBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Padding" Value="14" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>

            <Style x:Key="ConfigSectionTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ConfigTitleBrush}" />
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontWeight" Value="ExtraBold" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="ConfigSectionSubTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ConfigMutedTextBrush}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="ConfigFieldLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#334155" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="ExtraBold" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="Margin" Value="0,0,10,0" />
            </Style>

            <Style x:Key="ConfigTextBoxStyle" TargetType="TextBox">
                <Setter Property="Height" Value="38" />
                <Setter Property="MinHeight" Value="38" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="#0F172A" />
                <Setter Property="Background" Value="White" />
                <Setter Property="BorderBrush" Value="#CBD5E1" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="10,0" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="TextAlignment" Value="Left" />
                <Setter Property="Margin" Value="0,4" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Style.Triggers>
                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource ConfigInputFocusBrush}" />
                        <Setter Property="BorderThickness" Value="2" />
                    </Trigger>
                    <Trigger Property="IsReadOnly" Value="True">
                        <Setter Property="Background" Value="{StaticResource ConfigReadonlyBrush}" />
                        <Setter Property="Foreground" Value="#64748B" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.7" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ConfigButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="42" />
                <Setter Property="MinWidth" Value="96" />
                <Setter Property="Padding" Value="14,0" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Background" Value="{StaticResource ConfigPrimaryBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="ExtraBold" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ButtonBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="10"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ConfigDataGridTextStyle" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="TextAlignment" Value="Center" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="Padding" Value="8,0" />
                <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{StaticResource ConfigPageBackground}" Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="430" MinWidth="390" />
            <ColumnDefinition Width="14" />
            <ColumnDefinition Width="*" MinWidth="620" />
        </Grid.ColumnDefinitions>

        <!-- ===================== LEFT: PRODUCT FORM ===================== -->
        <Border Grid.Column="0" Style="{StaticResource ConfigCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="42"
                            Height="42"
                            CornerRadius="12"
                            Background="#DBEAFE"
                            VerticalAlignment="Top">
                        <TextBlock Text="CFG"
                                   Foreground="{StaticResource ConfigPrimaryBrush}"
                                   FontSize="13"
                                   FontWeight="ExtraBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="THÔNG TIN MÃ HÀNG"
                                   Style="{StaticResource ConfigSectionTitleStyle}" />
                        <TextBlock Text="Thêm, sửa hoặc kiểm tra định dạng QR theo từng mã sản phẩm."
                                   Style="{StaticResource ConfigSectionSubTitleStyle}"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1"
                        Height="1"
                        Background="#E2E8F0"
                        Margin="0,14,0,10" />

                <!-- Form content -->
                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False">
                    <Grid Margin="0,0,4,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="ID" Style="{StaticResource ConfigFieldLabelStyle}" />
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Text="{Binding CURR_ID}"
                                 IsReadOnly="True"
                                 Style="{StaticResource ConfigTextBoxStyle}"
                                 d:Text="1001" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="CAR" Style="{StaticResource ConfigFieldLabelStyle}" />
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Text="{Binding CURR_CAR, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ConfigTextBoxStyle}"
                                 d:Text="SX3" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="PART NO" Style="{StaticResource ConfigFieldLabelStyle}" />
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{Binding CURR_PARTNUMBER, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ConfigTextBoxStyle}"
                                 d:Text="N6375-001" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="PART NAME" Style="{StaticResource ConfigFieldLabelStyle}" />
                        <TextBox Grid.Row="3" Grid.Column="1"
                                 Text="{Binding CURR_PARTNAME, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ConfigTextBoxStyle}"
                                 d:Text="PART NAME SAMPLE" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="PREFIX" Style="{StaticResource ConfigFieldLabelStyle}" />
                        <TextBox Grid.Row="4" Grid.Column="1"
                                 Text="{Binding CURR_PREFIX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ConfigTextBoxStyle}"
                                 d:Text="ABC" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="SUFFIX" Style="{StaticResource ConfigFieldLabelStyle}" />
                        <TextBox Grid.Row="5" Grid.Column="1"
                                 Text="{Binding CURR_SUFFIX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ConfigTextBoxStyle}"
                                 d:Text="XYZ" />

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="SAMPLE" Style="{StaticResource ConfigFieldLabelStyle}" VerticalAlignment="Top" Margin="0,12,10,0" />
                        <TextBox Grid.Row="6" Grid.Column="1"
                                 Text="{Binding CURR_SAMPLE}"
                                 Style="{StaticResource ConfigTextBoxStyle}"
                                 Height="76"
                                 MinHeight="76"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 VerticalContentAlignment="Top"
                                 Padding="10,8"
                                 d:Text="THISISATEXTBOXTHISISATEXTBOXTHISISATEXTBOX" />

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="LENGTH" Style="{StaticResource ConfigFieldLabelStyle}" />
                        <TextBox Grid.Row="7" Grid.Column="1"
                                 Text="{Binding CURR_LENGTH, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ConfigTextBoxStyle}"
                                 d:Text="20" />

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="BOX QTY" Style="{StaticResource ConfigFieldLabelStyle}" />
                        <TextBox Grid.Row="8" Grid.Column="1"
                                 Text="{Binding CURR_QTY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ConfigTextBoxStyle}"
                                 d:Text="20" />
                    </Grid>
                </ScrollViewer>

                <!-- Actions -->
                <Grid Grid.Row="3" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource ConfigButtonStyle}"
                            Background="{StaticResource ConfigDangerBrush}"
                            Command="{Binding DELETECMD}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="XÓA" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2"
                            Style="{StaticResource ConfigButtonStyle}"
                            Background="{StaticResource ConfigSuccessBrush}"
                            Command="{Binding ADDCMD}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="THÊM" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="4"
                            Style="{StaticResource ConfigButtonStyle}"
                            Background="{StaticResource ConfigWarningBrush}"
                            Command="{Binding MODIFYCMD}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="SỬA" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <!-- ===================== RIGHT: SEARCH + TABLE ===================== -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Search card -->
            <Border Grid.Row="0" Style="{StaticResource ConfigCardStyle}" Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="42"
                            Height="42"
                            CornerRadius="12"
                            Background="#EEF2FF"
                            VerticalAlignment="Center">
                        <TextBlock Text="LIST"
                                   Foreground="{StaticResource ConfigPrimaryBrush}"
                                   FontSize="12"
                                   FontWeight="ExtraBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="DANH SÁCH CẤU HÌNH"
                                   Style="{StaticResource ConfigSectionTitleStyle}"
                                   FontSize="17" />
                        <TextBlock Text="Tìm theo Part Name và chọn dòng để đưa dữ liệu sang form bên trái."
                                   Style="{StaticResource ConfigSectionSubTitleStyle}"
                                   Margin="0,2,0,0" />
                    </StackPanel>

                    <Grid Grid.Column="3" Width="420" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="104" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#F8FAFC"
                                BorderBrush="#CBD5E1"
                                BorderThickness="1"
                                CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="38" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Grid.Column="0"
                                                         Kind="Magnify"
                                                         Width="20"
                                                         Height="20"
                                                         Foreground="#64748B"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center" />
                                <TextBox Grid.Column="1"
                                         Height="40"
                                         Text="{Binding InputProductNameSearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=220}"
                                         FontSize="14"
                                         FontWeight="SemiBold"
                                         VerticalContentAlignment="Center"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="0,0,10,0"
                                         ToolTip="Tìm theo Car / Part Number / Part Name / Prefix / Suffix"
                                         Foreground="#0F172A"
                                         d:Text="Nhập PartName cần tìm" />
                            </Grid>
                        </Border>

                        <Button Grid.Column="2"
                                Style="{StaticResource ConfigButtonStyle}"
                                Height="42"
                                MinWidth="104"
                                Background="{StaticResource ConfigPrimaryBrush}"
                                Command="{Binding SeachProductInfoCMD}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Search" Width="19" Height="19" VerticalAlignment="Center" />
                                <TextBlock Text="TÌM" Margin="7,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <!-- Table card -->
            <Border Grid.Row="2" Style="{StaticResource ConfigCardStyle}" Padding="0" ClipToBounds="True">
                <DataGrid ItemsSource="{Binding LabelProductInfoView}"
                          SelectedItem="{Binding SelectedProductInfoToModify, Mode=OneWayToSource}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          FontSize="13"
                          RowHeight="34"
                          ColumnHeaderHeight="38"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="False"
                          CanUserResizeRows="False"
                          CanUserResizeColumns="False"
                          CanUserSortColumns="False"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          BorderThickness="0"
                          Background="White"
                          AlternatingRowBackground="#F8FAFC"
                          HorizontalGridLinesBrush="#E2E8F0"
                          VerticalGridLinesBrush="Transparent"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.CanContentScroll="True"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">

                    <DataGrid.Resources>
                        <Style TargetType="ScrollBar">
                            <Setter Property="MinWidth" Value="10" />
                            <Setter Property="MinHeight" Value="10" />
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding ID}"
                                            Width="64"
                                            ElementStyle="{StaticResource ConfigDataGridTextStyle}" />

                        <DataGridTextColumn Header="CAR"
                                            Binding="{Binding Car}"
                                            Width="90"
                                            ElementStyle="{StaticResource ConfigDataGridTextStyle}" />

                        <DataGridTextColumn Header="PART NUMBER"
                                            Binding="{Binding PartNumber}"
                                            Width="150"
                                            ElementStyle="{StaticResource ConfigDataGridTextStyle}" />

                        <DataGridTextColumn Header="PART NAME"
                                            Binding="{Binding PartName}"
                                            Width="180"
                                            ElementStyle="{StaticResource ConfigDataGridTextStyle}" />

                        <DataGridTextColumn Header="CODE FORMAT"
                                            Binding="{Binding CodeStringForm}"
                                            Width="260"
                                            ElementStyle="{StaticResource ConfigDataGridTextStyle}" />

                        <DataGridTextColumn Header="PREFIX"
                                            Binding="{Binding CodePrefix}"
                                            Width="90"
                                            ElementStyle="{StaticResource ConfigDataGridTextStyle}" />

                        <DataGridTextColumn Header="SUFFIX"
                                            Binding="{Binding CodeSuffix}"
                                            Width="90"
                                            ElementStyle="{StaticResource ConfigDataGridTextStyle}" />

                        <DataGridTextColumn Header="LENGTH"
                                            Binding="{Binding CodeLength}"
                                            Width="88"
                                            ElementStyle="{StaticResource ConfigDataGridTextStyle}" />

                        <DataGridTextColumn Header="QTY"
                                            Binding="{Binding BoxQuantity}"
                                            Width="78"
                                            ElementStyle="{StaticResource ConfigDataGridTextStyle}" />

                        <DataGridCheckBoxColumn Header="VALID"
                                                Binding="{Binding IsValid, Mode=OneWay}"
                                                Width="78" />
                    </DataGrid.Columns>

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#1E40AF" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="FontWeight" Value="ExtraBold" />
                            <Setter Property="FontSize" Value="12" />
                            <Setter Property="Height" Value="38" />
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="Padding" Value="10,0" />
                            <Setter Property="BorderBrush" Value="#1D4ED8" />
                            <Setter Property="BorderThickness" Value="0,0,1,0" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White" />
                            <Setter Property="Foreground" Value="#0F172A" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="SnapsToDevicePixels" Value="True" />
                            <Style.Triggers>
                                <Trigger Property="AlternationIndex" Value="1">
                                    <Setter Property="Background" Value="#F8FAFC" />
                                    <Setter Property="Foreground" Value="#0F172A" />
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsMouseOver" Value="True" />
                                        <Condition Property="IsSelected" Value="False" />
                                    </MultiTrigger.Conditions>
                                    <Setter Property="Background" Value="#EFF6FF" />
                                    <Setter Property="Foreground" Value="#0F172A" />
                                </MultiTrigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2563EB" />
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="6,0" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Setter Property="TextBlock.TextAlignment" Value="Center" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="#0F172A" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2563EB" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="BorderThickness" Value="0" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="False">
                                    <Setter Property="Foreground" Value="#0F172A" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
