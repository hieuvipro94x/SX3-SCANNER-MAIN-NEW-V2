<UserControl x:Class="SX3_SCANER.Views.Controls.ScanLeftPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="CheckStatusDotStyle" TargetType="Border">
                <Setter Property="Width" Value="28"/>
                <Setter Property="Height" Value="28"/>
                <Setter Property="CornerRadius" Value="14"/>
                <Setter Property="Background" Value="#F1F5F9"/>
                <Setter Property="BorderBrush" Value="#CBD5E1"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="HorizontalAlignment" Value="Right"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="1">
                        <Setter Property="Background" Value="#ECFDF5"/>
                        <Setter Property="BorderBrush" Value="#22C55E"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="0">
                        <Setter Property="Background" Value="#FEF2F2"/>
                        <Setter Property="BorderBrush" Value="#DC2626"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="CheckStatusTextStyle" TargetType="TextBlock">
                <Setter Property="Text" Value="•"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="FontWeight" Value="Black"/>
                <Setter Property="Foreground" Value="#94A3B8"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=Tag}" Value="1">
                        <Setter Property="Text" Value="✓"/>
                        <Setter Property="Foreground" Value="#16A34A"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=Tag}" Value="0">
                        <Setter Property="Text" Value="!"/>
                        <Setter Property="Foreground" Value="#DC2626"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Box / session settings -->
        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="5" Height="22" CornerRadius="3" Background="{StaticResource PrimaryBrush}" Margin="0,0,8,0"/>
                        <TextBlock Text="THIẾT LẬP THÙNG" Style="{StaticResource SectionTitleStyle}"/>
                    </StackPanel>
                    <Border Grid.Column="1" CornerRadius="12" Padding="8,4" Background="{Binding CurrentBoxStatusBackground}" BorderBrush="{Binding CurrentBoxStatusBorderBrush}" BorderThickness="1">
                        <TextBlock Text="{Binding CurrentBoxStatusText}" FontSize="10.5" FontWeight="Black" Foreground="{Binding CurrentBoxStatusForeground}" TextTrimming="CharacterEllipsis"/>
                    </Border>
                </Grid>

                <Border Grid.Row="2" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="10,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="MÃ HÀNG" Style="{StaticResource FieldLabelStyle}" Foreground="{StaticResource PrimaryBrush}"/>
                        <ComboBox Grid.Row="2"
                                  MinWidth="0"
                                  Height="34"
                                  FontSize="13"
                                  FontWeight="SemiBold"
                                  ItemsSource="{Binding PartNumberList}"
                                  SelectedItem="{Binding SelectedPartNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  IsEnabled="{Binding CanModifySessionSelection}" />
                    </Grid>
                </Border>

                <UniformGrid Grid.Row="4" Columns="2" Rows="2">
                    <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="9,7" Margin="0,0,5,5">
                        <StackPanel>
                            <TextBlock Text="NGÀY BOX" Style="{StaticResource FieldLabelStyle}"/>
                            <DatePicker Height="30"
                                        FontSize="12.5"
                                        Language="vi-VN"
                                        SelectedDate="{Binding BoxDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        IsEnabled="{Binding CanSwitchProduct}" />
                        </StackPanel>
                    </Border>
                    <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="9,7" Margin="5,0,0,5">
                        <StackPanel>
                            <TextBlock Text="NGÀY TEM" Style="{StaticResource FieldLabelStyle}"/>
                            <DatePicker Height="30"
                                        FontSize="12.5"
                                        Language="vi-VN"
                                        SelectedDate="{Binding ScanLabelDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        IsEnabled="{Binding IsApplicationReady}" />
                        </StackPanel>
                    </Border>
                    <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="9,7" Margin="0,5,5,0">
                        <StackPanel>
                            <TextBlock Text="SỐ LƯỢNG/BOX" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Height="30" FontSize="13" FontWeight="Bold" HorizontalContentAlignment="Center" Text="{Binding SelectedQuantity}" IsEnabled="{Binding CanModifySessionSelection}" />
                        </StackPanel>
                    </Border>
                    <Border Background="#ECFDF5" BorderBrush="#BBF7D0" BorderThickness="1" CornerRadius="12" Padding="9,7" Margin="5,5,0,0">
                        <StackPanel>
                            <TextBlock Text="ĐÃ PASS" Style="{StaticResource FieldLabelStyle}" Foreground="{StaticResource OkBrush}"/>
                            <TextBlock Text="{Binding ScanQuantityText}" FontSize="15" FontWeight="Black" Foreground="{StaticResource TextMainBrush}" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Height="38" Content="HỦY THÙNG" FontSize="10" Style="{StaticResource DangerButton}" Command="{Binding CancelBoxCMD}">
                        <Button.Visibility>
                            <Binding Path="HasOpenScanSession" Converter="{StaticResource BooleanToVisibilityConverter}"/>
                        </Button.Visibility>
                    </Button>
                    <Button Grid.Column="2" Height="38" Content="ĐỔI PHIÊN" FontSize="10" Style="{StaticResource SecondaryButton}" Command="{Binding OpenSessionSetupCMD}"/>
                    <Button Grid.Column="4" Height="38" Content="ĐÓNG LẺ" FontSize="10" Style="{StaticResource WarningButton}" Command="{Binding ClosePartialBoxCMD}"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Expected code structure -->
        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Padding="14,12">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="CHUẨN KIỂM TRA" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="Các thành phần QR được dùng để đối chiếu khi scan." Style="{StaticResource SectionSubTitleStyle}" Margin="0,3,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="2" Style="{StaticResource ExpectedValueBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="P.NAME" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBlock Text="{Binding PNameExpected}" Style="{StaticResource ExpectedValueTextStyle}"/>
                            </StackPanel>
                            <Border Grid.Column="1" Tag="{Binding PName_OK}" Style="{StaticResource CheckStatusDotStyle}"><TextBlock Style="{StaticResource CheckStatusTextStyle}"/></Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="3" Style="{StaticResource ExpectedValueBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="DATE / SEAL" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBlock Text="{Binding SealNoExpected}" Style="{StaticResource ExpectedValueTextStyle}"/>
                            </StackPanel>
                            <Border Grid.Column="1" Tag="{Binding SealNo_OK}" Style="{StaticResource CheckStatusDotStyle}"><TextBlock Style="{StaticResource CheckStatusTextStyle}"/></Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="4" Style="{StaticResource ExpectedValueBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="LOT" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBlock Text="{Binding LotNoExpected}" Style="{StaticResource ExpectedValueTextStyle}"/>
                            </StackPanel>
                            <Border Grid.Column="1" Tag="{Binding LotNo_OK}" Style="{StaticResource CheckStatusDotStyle}"><TextBlock Style="{StaticResource CheckStatusTextStyle}"/></Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="5" Style="{StaticResource ExpectedValueBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="SUFFIX" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBlock Text="{Binding SuffixExpected}" Style="{StaticResource ExpectedValueTextStyle}"/>
                            </StackPanel>
                            <Border Grid.Column="1" Tag="{Binding Suffix_OK}" Style="{StaticResource CheckStatusDotStyle}"><TextBlock Style="{StaticResource CheckStatusTextStyle}"/></Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="6" Style="{StaticResource ExpectedValueBorderStyle}" Margin="0">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="ĐỘ DÀI QR" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBlock Text="{Binding CodeLengthExpected}" Style="{StaticResource ExpectedValueTextStyle}"/>
                            </StackPanel>
                            <Border Grid.Column="1" Tag="{Binding Length_OK}" Style="{StaticResource CheckStatusDotStyle}"><TextBlock Style="{StaticResource CheckStatusTextStyle}"/></Border>
                        </Grid>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="4" CornerRadius="14" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="txtAppVersion" Text="SCANER V" FontSize="11" FontWeight="Black" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                <TextBlock x:Name="txtDateTimeVersion" Grid.Column="1" Text="--/--/---- --:--:--" FontSize="11" FontWeight="Black" Foreground="{StaticResource TextMainBrush}" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
