<UserControl x:Class="SX3_SCANER.Views.Controls.HistorySearchTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:SX3_SCANER"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodel="clr-namespace:SX3_SCANER.ViewModel"
             d:DataContext="{d:DesignInstance Type=viewmodel:MainViewModel}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
<Grid Margin="10" Background="#F8FAFC">
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="42" />
    </Grid.RowDefinitions>

    <!-- Bộ lọc tìm kiếm -->
    <materialDesign:Card Padding="12"
             Margin="0,0,0,10"
             UniformCornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Bộ lọc dữ liệu scan"
           FontSize="18"
           FontWeight="SemiBold"
           Foreground="#1E293B"/>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" MinWidth="150" />
                    <ColumnDefinition Width="1.35*" MinWidth="175" />
                    <ColumnDefinition Width="1.25*" MinWidth="170" />
                    <ColumnDefinition Width="1.1*" MinWidth="150" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="1.25*" MinWidth="170" />
                    <ColumnDefinition Width="58" />
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Column="0"
              Margin="0,0,6,0"
              Height="40"
              FontSize="14"
              IsEnabled="True"
              ItemsSource="{Binding HistoryDataSources}"
              SelectedItem="{Binding SelectedHistoryDataSource, Mode=TwoWay}"
              ToolTip="Chọn nguồn dữ liệu thực tế đang tồn tại"
              materialDesign:HintAssist.Hint="Nguồn dữ liệu" />

                <TextBox Grid.Column="1"
              Margin="0,0,6,0"
              Height="40"
              FontSize="14"
              FontWeight="SemiBold"
              VerticalContentAlignment="Center"
              Text="{Binding HistorySearchKeyword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=220}"
              Padding="10,0"
              ToolTip="Tìm theo Product Part Number. Ví dụ nhập 028 sẽ ra WH322028"
              Foreground="#0F172A"
              materialDesign:HintAssist.Hint="Tìm Part Number" />

                <ComboBox Grid.Column="2"
              Margin="0,0,6,0"
              Height="40"
              FontSize="14"
              ItemsSource="{Binding ScanViewDistinctProductNumberList}"
              SelectedItem="{Binding SelectedDistinctProductNumber}"
              materialDesign:HintAssist.Hint="Part Number" />

                <ComboBox Grid.Column="3"
              Margin="0,0,6,0"
              Height="40"
              FontSize="14"
              ItemsSource="{Binding ScanViewDistinctSealNoList}"
              SelectedItem="{Binding SelectedDistinctSealNo}"
              materialDesign:HintAssist.Hint="Seal No" />

                <ComboBox Grid.Column="4"
              Margin="0,0,6,0"
              Height="40"
              MinWidth="90"
              FontSize="14"
              ItemsSource="{Binding ScanResultFilterOptions}"
              SelectedItem="{Binding SelectedScanResultFilter, Mode=TwoWay}"
              materialDesign:HintAssist.Hint="Kết quả" />

                <ComboBox Grid.Column="5"
              Margin="0,0,6,0"
              Height="40"
              FontSize="14"
              ItemsSource="{Binding ScanNGMessageList}"
              SelectedItem="{Binding SelectedScanNGMessage}"
              materialDesign:HintAssist.Hint="Lỗi / Scan Message" />

                <Button Grid.Column="6"
        Width="40"
        Height="32"
        Margin="0"
        Padding="0"
        HorizontalAlignment="Right"
        VerticalAlignment="Center"
        Command="{Binding QueryCMD}">
                    <materialDesign:PackIcon Kind="Search"
             Width="20"
             Height="20"
             HorizontalAlignment="Center"
             VerticalAlignment="Center"/>
                </Button>
            </Grid>
        </Grid>
    </materialDesign:Card>

    <!-- Bảng kết quả -->
    <materialDesign:Card Grid.Row="1"
             Padding="8"
             UniformCornerRadius="8">
        <DataGrid ItemsSource="{Binding HistoryResults}"
          AutoGenerateColumns="False"
          LoadingRow="SQLiteTable_LoadingRow"
          IsReadOnly="True"
          FontSize="12"
          RowHeight="32"
          HeadersVisibility="Column"
          GridLinesVisibility="Horizontal"
          CanUserAddRows="False"
          CanUserDeleteRows="False"
          CanUserResizeRows="False"
          CanUserResizeColumns="False"
          CanUserReorderColumns="False"
          CanUserSortColumns="False"
          SelectionMode="Single"
          Background="White"
          BorderThickness="0"
          HorizontalScrollBarVisibility="Auto"
          VerticalScrollBarVisibility="Auto"
          ScrollViewer.CanContentScroll="True"
          EnableRowVirtualization="True"
          EnableColumnVirtualization="True"
          VirtualizingPanel.IsVirtualizing="True"
          VirtualizingPanel.VirtualizationMode="Recycling"
          ColumnWidth="*"
          RowStyle="{StaticResource UnifiedScanRowStyle}">
            <DataGrid.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="TextAlignment" Value="Center"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="TextWrapping" Value="NoWrap"/>
                </Style>
                <Style TargetType="CheckBox">
                    <Setter Property="HorizontalAlignment" Value="Center"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                </Style>
                <Style x:Key="CenterTextColumnStyle" TargetType="TextBlock">
                    <Setter Property="HorizontalAlignment" Value="Center"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="TextAlignment" Value="Center"/>
                    <Setter Property="TextWrapping" Value="NoWrap"/>
                </Style>
                <Style x:Key="LeftTextColumnStyle" TargetType="TextBlock">
                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="TextAlignment" Value="Left"/>
                    <Setter Property="TextWrapping" Value="NoWrap"/>
                </Style>
                <Style x:Key="CenterCheckBoxStyle" TargetType="CheckBox">
                    <Setter Property="HorizontalAlignment" Value="Center"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                </Style>
                <Style x:Key="ColumnHeaderStyle" TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#F8FAFC"/>
                    <Setter Property="Foreground" Value="#0F172A"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Padding" Value="6,0"/>
                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                </Style>
                <Style x:Key="CellStyle" TargetType="DataGridCell">
                    <Setter Property="Padding" Value="6,0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.ColumnHeaderStyle>
                <StaticResource ResourceKey="ColumnHeaderStyle"/>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.CellStyle>
                <StaticResource ResourceKey="CellStyle"/>
            </DataGrid.CellStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="ScanTime"
                    Binding="{Binding ScanTime, StringFormat=dd/MM/yyyy HH:mm:ss}"
                    Width="1.3*"
                    ElementStyle="{StaticResource CenterTextColumnStyle}"/>
                <DataGridTextColumn Header="BoxName"
                    Binding="{Binding BoxName}"
                    Width="1.1*"
                    ElementStyle="{StaticResource CenterTextColumnStyle}"/>
                <DataGridTextColumn Header="ProductPartNumber"
                    Binding="{Binding ProductPartNumber}"
                    Width="1.2*"
                    ElementStyle="{StaticResource CenterTextColumnStyle}"/>
                <DataGridTextColumn Header="ProductPartName"
                    Binding="{Binding ProductPartName}"
                    Width="1.2*"
                    ElementStyle="{StaticResource CenterTextColumnStyle}"/>
                <DataGridTextColumn Header="SealNo"
                    Binding="{Binding SealNo}"
                    Width="0.8*"
                    ElementStyle="{StaticResource CenterTextColumnStyle}"/>
                <DataGridTextColumn Header="LotNo"
                    Binding="{Binding LotNo}"
                    Width="0.7*"
                    ElementStyle="{StaticResource CenterTextColumnStyle}"/>
                <DataGridTextColumn Header="ScanData"
                    Binding="{Binding ScanData}"
                    Width="1.8*"
                    ElementStyle="{StaticResource CenterTextColumnStyle}"/>
                <DataGridCheckBoxColumn Header="ScanResult"
                    Binding="{Binding ScanResult, Mode=OneWay}"
                    Width="0.8*"
                    ElementStyle="{StaticResource CenterCheckBoxStyle}"/>
                <DataGridTextColumn Header="ScanMessage"
                    Binding="{Binding ScanMessage}"
                    Width="1.5*"
                    ElementStyle="{StaticResource CenterTextColumnStyle}"/>
                <DataGridTextColumn Header="ScanWorker"
                    Binding="{Binding ScanWorker}"
                    Width="0.8*"
                    ElementStyle="{StaticResource CenterTextColumnStyle}"/>
                <DataGridTextColumn Header="ResultText"
                    Binding="{Binding ResultText}"
                    Width="0.8*"
                    ElementStyle="{StaticResource CenterTextColumnStyle}"/>
                <DataGridTextColumn Header="Loại thùng"
                    Binding="{Binding BoxTypeText}"
                    Width="1.0*"
                    ElementStyle="{StaticResource CenterTextColumnStyle}"/>
            </DataGrid.Columns>
        </DataGrid>
    </materialDesign:Card>

    <!-- Thanh trạng thái -->
    <Border Grid.Row="2"
Margin="0,12,0,0"
CornerRadius="10"
Background="#E2E8F0">
        <Grid Margin="14,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="{Binding QueryStatus}"
           VerticalAlignment="Center"
           FontSize="13"
           FontWeight="SemiBold"
           Foreground="#475569" />

            <TextBlock Grid.Column="1"
           VerticalAlignment="Center"
           FontSize="13"
           FontWeight="SemiBold"
           Foreground="#0F172A"
           Text="{Binding QueryTimes, StringFormat=Thời gian: {0} ms}" />

            <TextBlock Grid.Column="3"
           VerticalAlignment="Center"
           FontSize="13"
           FontWeight="SemiBold"
           Foreground="#0F172A"
           Text="{Binding RowCounts, StringFormat=Số dòng: {0}}" />
        </Grid>
    </Border>
</Grid>
</UserControl>
