<UserControl x:Class="SX3_SCANER.Views.Controls.HistorySearchTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="HistoryCardStyle" TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="14"/>
            </Style>

            <!-- Text hierarchy: dùng chung cho toàn bộ TextBlock trong tab lịch sử -->
            <Style x:Key="HistoryTextBaseStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
                <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
                <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
            </Style>

            <Style x:Key="HistoryPageTitleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource HistoryTextBaseStyle}">
                <Setter Property="FontSize" Value="18.5"/>
                <Setter Property="FontWeight" Value="Black"/>
                <Setter Property="Foreground" Value="#0F172A"/>
                <Setter Property="LineHeight" Value="23"/>
                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            </Style>

            <Style x:Key="HistoryPageSubtitleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource HistoryTextBaseStyle}">
                <Setter Property="FontSize" Value="12.3"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#64748B"/>
                <Setter Property="Margin" Value="0,3,0,0"/>
                <Setter Property="LineHeight" Value="18"/>
                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            </Style>

            <Style x:Key="HistorySectionTitleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource HistoryTextBaseStyle}">
                <Setter Property="FontSize" Value="13.2"/>
                <Setter Property="FontWeight" Value="Black"/>
                <Setter Property="Foreground" Value="#0F172A"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="FilterLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource HistoryTextBaseStyle}">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="Black"/>
                <Setter Property="Foreground" Value="#475569"/>
                <Setter Property="Margin" Value="3,0,0,6"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="HistoryHintTextStyle" TargetType="TextBlock" BasedOn="{StaticResource HistoryTextBaseStyle}">
                <Setter Property="FontSize" Value="10.8"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="#1D4ED8"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="HistoryButtonTextStyle" TargetType="TextBlock" BasedOn="{StaticResource HistoryTextBaseStyle}">
                <Setter Property="FontSize" Value="12.3"/>
                <Setter Property="FontWeight" Value="Black"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="HistoryCountBadgeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource HistoryTextBaseStyle}">
                <Setter Property="FontSize" Value="11.3"/>
                <Setter Property="FontWeight" Value="Black"/>
                <Setter Property="Foreground" Value="#334155"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="HistoryStatusTextStyle" TargetType="TextBlock" BasedOn="{StaticResource HistoryTextBaseStyle}">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="#334155"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            </Style>

            <Style x:Key="HistoryStatusPillTextStyle" TargetType="TextBlock" BasedOn="{StaticResource HistoryTextBaseStyle}">
                <Setter Property="FontSize" Value="10.8"/>
                <Setter Property="FontWeight" Value="Black"/>
                <Setter Property="Foreground" Value="#475569"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="HistoryEmptyTitleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource HistoryTextBaseStyle}">
                <Setter Property="FontSize" Value="13.5"/>
                <Setter Property="FontWeight" Value="Black"/>
                <Setter Property="Foreground" Value="#334155"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,10,0,0"/>
            </Style>

            <Style x:Key="HistoryEmptySubtitleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource HistoryTextBaseStyle}">
                <Setter Property="FontSize" Value="11.5"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#94A3B8"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,4,0,0"/>
            </Style>

            <Style x:Key="HistoryResultBadgeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource HistoryTextBaseStyle}">
                <Setter Property="FontSize" Value="10.8"/>
                <Setter Property="FontWeight" Value="Black"/>
                <Setter Property="Foreground" Value="#475569"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="HistoryTextBoxStyle" TargetType="TextBox">
                <Setter Property="Height" Value="40"/>
                <Setter Property="Padding" Value="12,0"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Foreground" Value="#0F172A"/>
                <Setter Property="Background" Value="#F8FAFC"/>
                <Setter Property="BorderBrush" Value="#CBD5E1"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <Style x:Key="HistoryComboBoxStyle" TargetType="ComboBox">
                <Setter Property="Height" Value="40"/>
                <Setter Property="Padding" Value="8,0"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Foreground" Value="#0F172A"/>
                <Setter Property="Background" Value="#F8FAFC"/>
                <Setter Property="BorderBrush" Value="#CBD5E1"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <Style x:Key="HistoryDatePickerStyle" TargetType="DatePicker">
                <Setter Property="Height" Value="40"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Foreground" Value="#0F172A"/>
                <Setter Property="Background" Value="#F8FAFC"/>
                <Setter Property="BorderBrush" Value="#CBD5E1"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <Style x:Key="HistoryPrimaryButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="40"/>
                <Setter Property="MinWidth" Value="118"/>
                <Setter Property="Padding" Value="16,0"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Background" Value="#2563EB"/>
                <Setter Property="BorderBrush" Value="#1D4ED8"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontSize" Value="12.5"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Surface"
                                    CornerRadius="11"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Surface" Property="Opacity" Value="0.90"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Surface" Property="Opacity" Value="0.76"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Surface" Property="Opacity" Value="0.45"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="HistoryColumnHeaderStyle" TargetType="DataGridColumnHeader">
                <Setter Property="Height" Value="44"/>
                <Setter Property="Background" Value="#EEF4FF"/>
                <Setter Property="Foreground" Value="#1E3A8A"/>
                <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="Black"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Padding" Value="9,0"/>
                <Setter Property="BorderBrush" Value="#DCE7F5"/>
                <Setter Property="BorderThickness" Value="0,0,1,1"/>
            </Style>

            <Style x:Key="HistoryCellStyle" TargetType="DataGridCell">
                <Setter Property="Padding" Value="10,0"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="BorderBrush" Value="#F1F5F9"/>
                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#DBEAFE"/>
                        <Setter Property="Foreground" Value="#1E3A8A"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="CenterHistoryTextStyle" TargetType="TextBlock" BasedOn="{StaticResource HistoryTextBaseStyle}">
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="TextAlignment" Value="Center"/>
                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                <Setter Property="FontSize" Value="12.2"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#1E293B"/>
                <Setter Property="LineHeight" Value="18"/>
            </Style>

            <Style x:Key="LeftHistoryTextStyle" TargetType="TextBlock" BasedOn="{StaticResource HistoryTextBaseStyle}">
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="TextAlignment" Value="Left"/>
                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                <Setter Property="FontSize" Value="12.2"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#1E293B"/>
                <Setter Property="LineHeight" Value="18"/>
                <Setter Property="Margin" Value="2,0,0,0"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="12" Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="42"/>
        </Grid.RowDefinitions>

        <!-- Page heading and primary actions -->
        <Border Grid.Row="0" Style="{StaticResource HistoryCardStyle}" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Width="42" Height="42" CornerRadius="13" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1">
                    <materialDesign:PackIcon Kind="History" Width="22" Height="22" Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="LỊCH SỬ SCAN &amp; XUẤT EXCEL" Style="{StaticResource HistoryPageTitleTextStyle}"/>
                    <TextBlock Text="Tra cứu dữ liệu theo điều kiện và xuất báo cáo Excel khi cần đối soát." Style="{StaticResource HistoryPageSubtitleTextStyle}"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding QueryCMD}" Style="{StaticResource HistoryPrimaryButtonStyle}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Magnify" Width="17" Height="17" Margin="0,0,7,0"/>
                            <TextBlock Text="TÌM KIẾM" Style="{StaticResource HistoryButtonTextStyle}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ExportHistoryCMD}"
                            Style="{StaticResource HistoryPrimaryButtonStyle}"
                            MinWidth="142"
                            Background="#16A34A"
                            BorderBrush="#15803D">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="MicrosoftExcel" Width="18" Height="18" Margin="0,0,7,0"/>
                            <TextBlock Text="XUẤT EXCEL" Style="{StaticResource HistoryButtonTextStyle}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding OpenExportFolderCMD}"
                            Style="{StaticResource HistoryPrimaryButtonStyle}"
                            MinWidth="56"
                            Margin="8,0,0,0"
                            Background="#475569"
                            BorderBrush="#334155"
                            ToolTip="Mở thư mục chứa file Excel đã xuất">
                        <materialDesign:PackIcon Kind="FolderOpen"
                                                 Width="19"
                                                 Height="19"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Search filters -->
        <Border Grid.Row="2" Style="{StaticResource HistoryCardStyle}" Padding="16,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="4" Height="18" CornerRadius="2" Background="#2563EB" Margin="0,0,8,0"/>
                        <TextBlock Text="BỘ LỌC DỮ LIỆU" Style="{StaticResource HistorySectionTitleTextStyle}"/>
                    </StackPanel>
                    <Border Grid.Column="1" Padding="9,4" CornerRadius="9" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="#3B82F6" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Tự động cập nhật khi đổi bộ lọc" Style="{StaticResource HistoryHintTextStyle}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.6*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="145"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="TỪ KHÓA / PART NUMBER" Style="{StaticResource FilterLabelStyle}"/>
                        <TextBox Style="{StaticResource HistoryTextBoxStyle}"
                                 Text="{Binding HistorySearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Nhập mã cần tìm..."
                                 ToolTip="Có thể nhập một phần mã hàng, ví dụ 028 để tìm WH322028"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="TỪ NGÀY" Style="{StaticResource FilterLabelStyle}"/>
                        <DatePicker Style="{StaticResource HistoryDatePickerStyle}"
                                    SelectedDate="{Binding HistoryFromDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="ĐẾN NGÀY" Style="{StaticResource FilterLabelStyle}"/>
                        <DatePicker Style="{StaticResource HistoryDatePickerStyle}"
                                    SelectedDate="{Binding HistoryToDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="6">
                        <TextBlock Text="KẾT QUẢ" Style="{StaticResource FilterLabelStyle}"/>
                        <ComboBox Style="{StaticResource HistoryComboBoxStyle}"
                                  ItemsSource="{Binding ScanResultFilterOptions}"
                                  SelectedItem="{Binding SelectedScanResultFilter, Mode=TwoWay}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="8">
                        <TextBlock Text="SỐ DÒNG" Style="{StaticResource FilterLabelStyle}"/>
                        <ComboBox Style="{StaticResource HistoryComboBoxStyle}"
                                  ItemsSource="{Binding QueryLimitOptions}"
                                  SelectedItem="{Binding SelectedQueryLimit}"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.05*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1.05*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1.4*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="MÃ HÀNG" Style="{StaticResource FilterLabelStyle}"/>
                        <ComboBox Style="{StaticResource HistoryComboBoxStyle}"
                                  ItemsSource="{Binding ScanViewDistinctProductNumberList}"
                                  SelectedItem="{Binding SelectedDistinctProductNumber}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="SEAL NO" Style="{StaticResource FilterLabelStyle}"/>
                        <ComboBox Style="{StaticResource HistoryComboBoxStyle}"
                                  ItemsSource="{Binding ScanViewDistinctSealNoList}"
                                  SelectedItem="{Binding SelectedDistinctSealNo}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="LỖI / THÔNG BÁO" Style="{StaticResource FilterLabelStyle}"/>
                        <ComboBox Style="{StaticResource HistoryComboBoxStyle}"
                                  ItemsSource="{Binding ScanNGMessageList}"
                                  SelectedItem="{Binding SelectedScanNGMessage}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Result table -->
        <Border Grid.Row="4" Style="{StaticResource HistoryCardStyle}" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="48"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Margin="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="TableLarge" Width="18" Height="18" Foreground="#2563EB" Margin="0,0,8,0"/>
                        <TextBlock Text="DỮ LIỆU LỊCH SỬ" Style="{StaticResource HistorySectionTitleTextStyle}"/>
                    </StackPanel>
                    <Border Grid.Column="1" Padding="10,5" CornerRadius="10" Background="#F1F5F9" VerticalAlignment="Center">
                        <TextBlock Text="{Binding RowCounts, StringFormat={}{0:N0} dòng}" Style="{StaticResource HistoryCountBadgeTextStyle}"/>
                    </Border>
                </Grid>

                <Grid Grid.Row="1">
                    <DataGrid ItemsSource="{Binding HistoryResults}"
                              AutoGenerateColumns="False"
                              LoadingRow="SQLiteTable_LoadingRow"
                              IsReadOnly="True"
                              FontSize="12.2"
                              RowHeight="38"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              CanUserResizeColumns="False"
                              CanUserReorderColumns="False"
                              CanUserSortColumns="False"
                              SelectionMode="Single"
                              Background="White"
                              RowBackground="White"
                              AlternatingRowBackground="#F8FAFC"
                              BorderThickness="1,1,0,0"
                              BorderBrush="#E2E8F0"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ColumnHeaderStyle="{StaticResource HistoryColumnHeaderStyle}"
                              CellStyle="{StaticResource HistoryCellStyle}"
                              RowStyle="{StaticResource UnifiedScanRowStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="THỜI GIAN" Binding="{Binding ScanTime, StringFormat=dd/MM/yyyy HH:mm:ss}" Width="145" ElementStyle="{StaticResource CenterHistoryTextStyle}"/>
                            <DataGridTextColumn Header="TÊN THÙNG" Binding="{Binding BoxName}" Width="120" ElementStyle="{StaticResource CenterHistoryTextStyle}"/>
                            <DataGridTextColumn Header="MÃ HÀNG" Binding="{Binding ProductPartNumber}" Width="125" ElementStyle="{StaticResource CenterHistoryTextStyle}"/>
                            <DataGridTextColumn Header="TÊN SẢN PHẨM" Binding="{Binding ProductPartName}" Width="150" ElementStyle="{StaticResource LeftHistoryTextStyle}"/>
                            <DataGridTextColumn Header="SEAL NO" Binding="{Binding SealNo}" Width="105" ElementStyle="{StaticResource CenterHistoryTextStyle}"/>
                            <DataGridTextColumn Header="LOT NO" Binding="{Binding LotNo}" Width="95" ElementStyle="{StaticResource CenterHistoryTextStyle}"/>
                            <DataGridTextColumn Header="MÃ SCAN" Binding="{Binding ScanData}" Width="220" ElementStyle="{StaticResource LeftHistoryTextStyle}"/>
                            <DataGridTemplateColumn Header="KẾT QUẢ" Width="82">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border x:Name="ResultBadge" Padding="10,4" CornerRadius="10" Background="#F1F5F9" HorizontalAlignment="Center">
                                            <TextBlock x:Name="ResultLabel" Text="{Binding ResultText}" Style="{StaticResource HistoryResultBadgeTextStyle}"/>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding ResultText}" Value="PASS">
                                                <Setter TargetName="ResultBadge" Property="Background" Value="#DCFCE7"/>
                                                <Setter TargetName="ResultLabel" Property="Foreground" Value="#15803D"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ResultText}" Value="NG">
                                                <Setter TargetName="ResultBadge" Property="Background" Value="#FEE2E2"/>
                                                <Setter TargetName="ResultLabel" Property="Foreground" Value="#B91C1C"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="THÔNG BÁO" Binding="{Binding ScanMessage}" Width="180" ElementStyle="{StaticResource LeftHistoryTextStyle}"/>
                            <DataGridTextColumn Header="NGƯỜI QUÉT" Binding="{Binding ScanWorker}" Width="105" ElementStyle="{StaticResource CenterHistoryTextStyle}"/>
                            <DataGridTextColumn Header="LOẠI THÙNG" Binding="{Binding BoxTypeText}" Width="105" ElementStyle="{StaticResource CenterHistoryTextStyle}"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HistoryResults.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Border Width="54" Height="54" CornerRadius="27" Background="#F1F5F9" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="DatabaseSearch" Width="26" Height="26" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Chưa có dữ liệu phù hợp" Style="{StaticResource HistoryEmptyTitleTextStyle}"/>
                        <TextBlock Text="Hãy thay đổi bộ lọc hoặc chọn khoảng ngày khác." Style="{StaticResource HistoryEmptySubtitleTextStyle}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Query status -->
        <Border Grid.Row="6" CornerRadius="12" Background="#F8FAFC" BorderBrush="#DCE7F5" BorderThickness="1" Padding="14,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Ellipse Width="7" Height="7" Fill="#3B82F6" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{Binding QueryStatus}" Style="{StaticResource HistoryStatusTextStyle}"/>
                <Border Grid.Column="3" Padding="9,4" CornerRadius="8" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding QueryTimes, StringFormat=Thời gian: {0} ms}" Style="{StaticResource HistoryStatusPillTextStyle}"/>
                </Border>
                <Border Grid.Column="5" Padding="9,4" CornerRadius="8" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding RowCounts, StringFormat=Số dòng: {0:N0}}" Style="{StaticResource HistoryStatusPillTextStyle}"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
