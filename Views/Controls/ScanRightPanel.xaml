<UserControl x:Class="SX3_SCANER.Views.Controls.ScanRightPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:SX3_SCANER"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodel="clr-namespace:SX3_SCANER.ViewModel"
             d:DataContext="{d:DesignInstance Type=viewmodel:MainViewModel}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
<materialDesign:Card Grid.Row="1"
                     Grid.Column="2"
                     Margin="4,4,4,4"
                     UniformCornerRadius="14">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- RESULT -->
        <Border x:Name="ScanResultBorder"
                Grid.Row="0"
                CornerRadius="22"
                Padding="20,18"
                Margin="12,10,12,12"
                Background="{Binding ResultBackgroundBrush}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                MinHeight="220"
                Opacity="1"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect Color="#334155"
                                  BlurRadius="24"
                                  ShadowDepth="4"
                                  Direction="270"
                                  Opacity="0.28"/>
            </Border.Effect>
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ScanTextResult}" Value="OK">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)">
                                            <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.14" Value="1.08">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.32" Value="1">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut"/>
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
                                            <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.14" Value="1.08">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.32" Value="1">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut"/>
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0.82"
                                                         To="1"
                                                         Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ScanTextResult}" Value="NG">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)">
                                            <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.14" Value="1.08">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.32" Value="1">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut"/>
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
                                            <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.14" Value="1.08">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.32" Value="1">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut"/>
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0.78"
                                                         To="1"
                                                         Duration="0:0:0.20">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid HorizontalAlignment="Stretch"
                  VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           FontSize="46"
                           FontWeight="ExtraBold"
                           Foreground="#FFFFFF"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           LineHeight="50"
                           LineStackingStrategy="BlockLineHeight">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#0F172A"
                                          BlurRadius="12"
                                          ShadowDepth="1"
                                          Opacity="0.30"/>
                    </TextBlock.Effect>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ScanTextResult}" Value="OK">
                                    <Setter Property="Text" Value="&#x2714;"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ScanTextResult}" Value="NG">
                                    <Setter Property="Text" Value="&#x2716;"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Grid.Row="1"
                           Margin="0,6,0,0"
                           FontSize="40"
                           FontWeight="ExtraBold"
                           Foreground="#FFFFFF"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           LineHeight="62"
                           LineStackingStrategy="BlockLineHeight">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#0F172A"
                                          BlurRadius="14"
                                          ShadowDepth="1"
                                          Opacity="0.34"/>
                    </TextBlock.Effect>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ScanTextResult}" Value="OK">
                                    <Setter Property="Text" Value="KẾT QUẢ SCAN: OK"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ScanTextResult}" Value="NG">
                                    <Setter Property="Text" Value="KẾT QUẢ SCAN: NG"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Grid.Row="2"
                           Text="{Binding ScanResultDetailText}"
                           Margin="8,14,8,0"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFF"
                           HorizontalAlignment="Stretch"
                           TextAlignment="Left"
                           TextWrapping="Wrap"
                           LineHeight="32"
                           LineStackingStrategy="BlockLineHeight"
                           Opacity="0.95"/>
            </Grid>
        </Border>

        <!-- FILTER -->
        <TextBox Grid.Row="1"
         Height="36"
         Margin="4"
         FontSize="14"
         VerticalContentAlignment="Center"
         Text="{Binding BoxNameForFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <!-- TABLE -->
        <DataGrid Grid.Row="2"
      ItemsSource="{Binding ToDayBoxView}"
      SelectedItem="{Binding SelectedTodayBox, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
      IsReadOnly="True"
      Margin="3"
      AutoGenerateColumns="False"
      FontSize="13"
      RowHeight="34"
      ColumnHeaderHeight="34"
      HeadersVisibility="Column"
      GridLinesVisibility="Horizontal"
      HorizontalScrollBarVisibility="Disabled"
      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
      CanUserResizeColumns="False"
      CanUserResizeRows="False"
      CanUserAddRows="False"
      CanUserDeleteRows="False"
      SelectionMode="Single"
      BorderThickness="0"
      ColumnHeaderStyle="{StaticResource UnifiedScanDataGridColumnHeaderStyle}"
      RowStyle="{StaticResource UnifiedScanRowStyle}"
      Background="White">

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="4,0"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                    <Setter Property="TextBlock.TextTrimming" Value="CharacterEllipsis"/>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.Columns>

                <!-- PNAME -->
                <DataGridTextColumn Header="Mã hàng"
        Binding="{Binding ProductPartNumber}"
        Width="1.35*"
        MinWidth="110" />

                <!-- SEAL -->
                <DataGridTextColumn Header="Ngày"
        Binding="{Binding BoxSealNo}"
        Width="0.8*"
        MinWidth="76" />

                <!-- SCAN -->
                <DataGridTemplateColumn Header="Số lượng"
            Width="0.85*"
            MinWidth="84">

                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Số thùng" />
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>

                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>

                            <Border CornerRadius="8"
        Padding="5,3"
        MinHeight="24"
        HorizontalAlignment="Center">

                                <Border.Style>
                                    <Style TargetType="Border">

                                        <Setter Property="Background" Value="White"/>

                                        <Style.Triggers>

                                            <!-- DONE -->
                                            <DataTrigger Binding="{Binding BoxComplete}" Value="True">
                                                <Setter Property="Background" Value="#DCFCE7"/>
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding IsPartialBox}" Value="True">
                                                <Setter Property="Background" Value="#FEF3C7"/>
                                            </DataTrigger>

                                        </Style.Triggers>

                                    </Style>
                                </Border.Style>

                                <TextBlock HorizontalAlignment="Center"
               VerticalAlignment="Center"
               FontWeight="Bold"
               FontSize="13"
               LineHeight="16"
               LineStackingStrategy="BlockLineHeight">

                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">

                                            <Setter Property="Foreground" Value="#0F172A"/>

                                            <Style.Triggers>

                                                <DataTrigger Binding="{Binding BoxComplete}" Value="True">
                                                    <Setter Property="Foreground" Value="#166534"/>
                                                </DataTrigger>

                                                <DataTrigger Binding="{Binding IsPartialBox}" Value="True">
                                                    <Setter Property="Foreground" Value="#B45309"/>
                                                </DataTrigger>

                                            </Style.Triggers>

                                        </Style>
                                    </TextBlock.Style>

                                    <TextBlock.Text>
                                        <Binding Path="ProgressText"/>
                                    </TextBlock.Text>

                                </TextBlock>

                            </Border>

                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>

                </DataGridTemplateColumn>

                <!-- DONE -->
                <DataGridTextColumn Header="Trạng thái"
            Binding="{Binding BoxCompleteText}"
            Width="1.0*"
            MinWidth="92"
            IsReadOnly="True" />

                <DataGridTextColumn Header="Loại thùng"
            Binding="{Binding BoxTypeText}"
            Width="1.0*"
            MinWidth="92"
            IsReadOnly="True" />

            </DataGrid.Columns>

        </DataGrid>

        <!-- BUTTON -->
        <Grid Grid.Row="3" Margin="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Button Content="Xem"
Grid.Column="0"
Margin="4"
Height="38"
FontSize="13"
Command="{Binding OpenBoxCMD}" />

            <Button Content="Scan"
Grid.Column="1"
Margin="4"
Height="38"
FontSize="13"
Command="{Binding SetSelectedBoxOnJobCMD}" />
        </Grid>
    </Grid>
</materialDesign:Card>
</UserControl>
