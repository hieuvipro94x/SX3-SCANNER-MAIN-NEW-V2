<UserControl x:Class="SX3_SCANER.Views.Controls.ScanRightPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!--
                Modern animated progress bar for current box.
                Giữ nguyên cơ chế ProgressBar chuẩn của WPF bằng PART_Track/PART_Indicator
                để Value/Maximum binding vẫn hoạt động ổn định.
            -->
            <Style x:Key="AnimatedBoxProgressBarStyle" TargetType="{x:Type ProgressBar}">
                <Setter Property="Height" Value="30"/>
                <Setter Property="MinHeight" Value="30"/>
                <Setter Property="Background" Value="#E2E8F0"/>
                <Setter Property="Foreground" Value="{StaticResource OkBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ProgressBar}">
                            <Grid x:Name="ProgressRoot"
                                  Height="{TemplateBinding Height}"
                                  MinHeight="{TemplateBinding MinHeight}"
                                  ClipToBounds="False">

                                <!-- Outer glow: tạo cảm giác thanh tiến độ nổi lên khỏi card -->
                                <Border x:Name="ProgressGlow"
                                        CornerRadius="15"
                                        Background="Transparent"
                                        Opacity="0.8">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="16"
                                                          ShadowDepth="0"
                                                          Opacity="0.16"
                                                          Color="#16A34A"/>
                                    </Border.Effect>
                                </Border>

                                <!-- Track nền -->
                                <Border x:Name="ProgressTrack"
                                        CornerRadius="15"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="#CBD5E1"
                                        BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8"
                                                          ShadowDepth="0"
                                                          Opacity="0.08"
                                                          Color="#0F172A"/>
                                    </Border.Effect>
                                </Border>

                                <!-- Track nội bộ. WPF sẽ tự scale PART_Indicator theo Value/Maximum -->
                                <Grid x:Name="PART_Track"
                                      Margin="2"
                                      ClipToBounds="True">
                                    <Grid x:Name="PART_Indicator"
                                          HorizontalAlignment="Left"
                                          ClipToBounds="True">

                                        <!-- Fill gradient chính -->
                                        <Border x:Name="ProgressFill"
                                                CornerRadius="13">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                    <GradientStop Color="#0EA5E9" Offset="0"/>
                                                    <GradientStop Color="#22C55E" Offset="0.55"/>
                                                    <GradientStop Color="#86EFAC" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>

                                        <!-- Vân sọc nhẹ, giúp thanh có cảm giác đang chạy -->
                                        <Rectangle x:Name="ProgressStripes"
                                                   Opacity="0.16"
                                                   IsHitTestVisible="False">
                                            <Rectangle.Fill>
                                                <DrawingBrush TileMode="Tile"
                                                              Viewport="0,0,26,26"
                                                              ViewportUnits="Absolute">
                                                    <DrawingBrush.Transform>
                                                        <TranslateTransform x:Name="StripeTransform" X="0"/>
                                                    </DrawingBrush.Transform>
                                                    <DrawingBrush.Drawing>
                                                        <GeometryDrawing Brush="#FFFFFF">
                                                            <GeometryDrawing.Geometry>
                                                                <GeometryGroup>
                                                                    <RectangleGeometry Rect="0,0,8,26">
                                                                        <RectangleGeometry.Transform>
                                                                            <SkewTransform AngleX="-28"/>
                                                                        </RectangleGeometry.Transform>
                                                                    </RectangleGeometry>
                                                                </GeometryGroup>
                                                            </GeometryDrawing.Geometry>
                                                        </GeometryDrawing>
                                                    </DrawingBrush.Drawing>
                                                </DrawingBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>

                                        <!-- Shine chạy ngang -->
                                        <Rectangle x:Name="ProgressShine"
                                                   Width="92"
                                                   HorizontalAlignment="Left"
                                                   Opacity="0.45"
                                                   IsHitTestVisible="False">
                                            <Rectangle.Fill>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#00FFFFFF" Offset="0"/>
                                                    <GradientStop Color="#D9FFFFFF" Offset="0.5"/>
                                                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                            <Rectangle.RenderTransform>
                                                <TranslateTransform x:Name="ProgressShineTransform" X="-130"/>
                                            </Rectangle.RenderTransform>
                                        </Rectangle>

                                        <!-- Đốm sáng ở đầu thanh tiến độ -->
                                        <Ellipse x:Name="ProgressTip"
                                                 Width="16"
                                                 Height="16"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,5,0"
                                                 Opacity="0.7"
                                                 IsHitTestVisible="False"
                                                 RenderTransformOrigin="0.5,0.5">
                                            <Ellipse.Fill>
                                                <RadialGradientBrush>
                                                    <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                                    <GradientStop Color="#66FFFFFF" Offset="0.48"/>
                                                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                                                </RadialGradientBrush>
                                            </Ellipse.Fill>
                                            <Ellipse.RenderTransform>
                                                <ScaleTransform x:Name="ProgressTipScale" ScaleX="1" ScaleY="1"/>
                                            </Ellipse.RenderTransform>
                                        </Ellipse>
                                    </Grid>
                                </Grid>

                                <!-- Highlight viền trên cho cảm giác kính -->
                                <Border CornerRadius="15"
                                        BorderThickness="1"
                                        Opacity="0.35"
                                        IsHitTestVisible="False">
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                </Border>
                            </Grid>

                            <ControlTemplate.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <!-- Shine chậm, mượt, không gây rối mắt -->
                                            <DoubleAnimation Storyboard.TargetName="ProgressShineTransform"
                                                             Storyboard.TargetProperty="X"
                                                             From="-130"
                                                             To="620"
                                                             Duration="0:0:2.25"
                                                             RepeatBehavior="Forever"/>

                                            <!-- Vân sọc trượt nhẹ -->
                                            <DoubleAnimation Storyboard.TargetName="StripeTransform"
                                                             Storyboard.TargetProperty="X"
                                                             From="0"
                                                             To="26"
                                                             Duration="0:0:1.2"
                                                             RepeatBehavior="Forever"/>

                                            <!-- Tip pulse -->
                                            <DoubleAnimation Storyboard.TargetName="ProgressTipScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             From="0.85"
                                                             To="1.25"
                                                             Duration="0:0:0.85"
                                                             AutoReverse="True"
                                                             RepeatBehavior="Forever"/>
                                            <DoubleAnimation Storyboard.TargetName="ProgressTipScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             From="0.85"
                                                             To="1.25"
                                                             Duration="0:0:0.85"
                                                             AutoReverse="True"
                                                             RepeatBehavior="Forever"/>
                                            <DoubleAnimation Storyboard.TargetName="ProgressTip"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="0.45"
                                                             To="0.9"
                                                             Duration="0:0:0.85"
                                                             AutoReverse="True"
                                                             RepeatBehavior="Forever"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>

                                <!-- Chưa có tem nào: ẩn glow/shine/tip để giao diện sạch hơn -->
                                <Trigger Property="Value" Value="0">
                                    <Setter TargetName="ProgressGlow" Property="Opacity" Value="0"/>
                                    <Setter TargetName="ProgressShine" Property="Opacity" Value="0"/>
                                    <Setter TargetName="ProgressTip" Property="Opacity" Value="0"/>
                                    <Setter TargetName="ProgressStripes" Property="Opacity" Value="0.08"/>
                                </Trigger>

                                <!-- Disable: chuyển về xám -->
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="ProgressFill" Property="Opacity" Value="0.45"/>
                                    <Setter TargetName="ProgressShine" Property="Opacity" Value="0"/>
                                    <Setter TargetName="ProgressTip" Property="Opacity" Value="0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Box progress -->
        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="THÙNG HIỆN TẠI" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="{Binding CurrentBoxNameText}" FontSize="20" FontWeight="Black" Foreground="{StaticResource TextMainBrush}" TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" CornerRadius="14" Padding="10,6" Background="{Binding CurrentBoxStatusBackground}" BorderBrush="{Binding CurrentBoxStatusBorderBrush}" BorderThickness="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentBoxStatusText}" FontSize="11" FontWeight="Black" Foreground="{Binding CurrentBoxStatusForeground}"/>
                    </Border>
                </Grid>
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="TIẾN ĐỘ" Style="{StaticResource FieldLabelStyle}" Foreground="{StaticResource OkBrush}"/>
                    </Grid>
                    <Grid Grid.Row="2" Height="34">
                        <ProgressBar Minimum="0"
                                     Maximum="{Binding SelectedQuantity}"
                                     Value="{Binding CurrentScanProgress}"
                                     Style="{StaticResource AnimatedBoxProgressBarStyle}"
                                     Foreground="{StaticResource OkBrush}"
                                     Background="#E2E8F0"
                                     Height="30"
                                     VerticalAlignment="Center"/>

                        <!-- Chỉ hiển thị phần trăm, không hiển thị số lượng dạng 0/10 -->
                        <TextBlock Text="{Binding CurrentProgressPercentText}"
                                   FontSize="13"
                                   FontWeight="Black"
                                   Foreground="#0F172A"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="5"
                                                  ShadowDepth="0"
                                                  Opacity="0.75"
                                                  Color="#FFFFFF"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="2" Columns="3">
            <Border CornerRadius="14" Background="#ECFDF5" BorderBrush="#BBF7D0" BorderThickness="1" Padding="10,8" Margin="0,0,5,0">
                <StackPanel>
                    <TextBlock Text="PASS" FontSize="11" FontWeight="Black" Foreground="{StaticResource OkBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentPassCount}" FontSize="24" FontWeight="Black" Foreground="{StaticResource TextMainBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border CornerRadius="14" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" Padding="10,8" Margin="5,0">
                <StackPanel>
                    <TextBlock Text="NG" FontSize="11" FontWeight="Black" Foreground="{StaticResource NgBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentNgCount}" FontSize="24" FontWeight="Black" Foreground="{StaticResource TextMainBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border CornerRadius="14" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" Padding="10,8" Margin="5,0,0,0">
                <StackPanel>
                    <TextBlock Text="HOÀN THÀNH" FontSize="10" FontWeight="Black" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentProgressPercentText}" FontSize="24" FontWeight="Black" Foreground="{StaticResource TextMainBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Latest scan result: light background, strong badge only -->
        <Border Grid.Row="4" Padding="20" MinHeight="280">
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ScanTextResult}" Value="OK">
                            <Setter Property="BorderBrush" Value="#22C55E"/>
                            <Setter Property="BorderThickness" Value="2"/>
                            <Setter Property="Background" Value="#F7FEFA"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ScanTextResult}" Value="PASS">
                            <Setter Property="BorderBrush" Value="#22C55E"/>
                            <Setter Property="BorderThickness" Value="2"/>
                            <Setter Property="Background" Value="#F7FEFA"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ScanTextResult}" Value="NG">
                            <Setter Property="BorderBrush" Value="#DC2626"/>
                            <Setter Property="BorderThickness" Value="2"/>
                            <Setter Property="Background" Value="#FFF7F7"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.14" Color="#334155"/>
            </Border.Effect>
            <Grid>
                <Grid.Triggers>
                    <EventTrigger RoutedEvent="Binding.TargetUpdated">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="ResultHaloScale"
                                                 Storyboard.TargetProperty="ScaleX"
                                                 From="0.72" To="1.55" Duration="0:0:0.55"
                                                 AutoReverse="True" RepeatBehavior="2x"/>
                                <DoubleAnimation Storyboard.TargetName="ResultHaloScale"
                                                 Storyboard.TargetProperty="ScaleY"
                                                 From="0.72" To="1.55" Duration="0:0:0.55"
                                                 AutoReverse="True" RepeatBehavior="2x"/>
                                <DoubleAnimation Storyboard.TargetName="ResultHalo"
                                                 Storyboard.TargetProperty="Opacity"
                                                 From="0.58" To="0" Duration="0:0:0.55"
                                                 AutoReverse="True" RepeatBehavior="2x"/>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ResultBadgeScale"
                                                               Storyboard.TargetProperty="ScaleX">
                                    <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.78"/>
                                    <SplineDoubleKeyFrame KeyTime="0:0:0.16" Value="1.18"/>
                                    <SplineDoubleKeyFrame KeyTime="0:0:0.34" Value="1"/>
                                </DoubleAnimationUsingKeyFrames>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ResultBadgeScale"
                                                               Storyboard.TargetProperty="ScaleY">
                                    <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.78"/>
                                    <SplineDoubleKeyFrame KeyTime="0:0:0.16" Value="1.18"/>
                                    <SplineDoubleKeyFrame KeyTime="0:0:0.34" Value="1"/>
                                </DoubleAnimationUsingKeyFrames>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ResultTextScale"
                                                               Storyboard.TargetProperty="ScaleX">
                                    <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.86"/>
                                    <SplineDoubleKeyFrame KeyTime="0:0:0.14" Value="1.13"/>
                                    <SplineDoubleKeyFrame KeyTime="0:0:0.30" Value="1"/>
                                </DoubleAnimationUsingKeyFrames>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ResultTextScale"
                                                               Storyboard.TargetProperty="ScaleY">
                                    <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.86"/>
                                    <SplineDoubleKeyFrame KeyTime="0:0:0.14" Value="1.13"/>
                                    <SplineDoubleKeyFrame KeyTime="0:0:0.30" Value="1"/>
                                </DoubleAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Grid.Triggers>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="KẾT QUẢ SCAN MỚI NHẤT" Style="{StaticResource SectionTitleStyle}" HorizontalAlignment="Center"/>

                <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Grid Width="136" Height="136" HorizontalAlignment="Center">
                        <Ellipse x:Name="ResultHalo"
                                 Width="118"
                                 Height="118"
                                 Opacity="0"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="ResultHaloScale" ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#CBD5E1"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ScanTextResult}" Value="OK">
                                            <Setter Property="Fill" Value="#86EFAC"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ScanTextResult}" Value="PASS">
                                            <Setter Property="Fill" Value="#86EFAC"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ScanTextResult}" Value="NG">
                                            <Setter Property="Fill" Value="#FCA5A5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <Border Width="106" Height="106" CornerRadius="53" HorizontalAlignment="Center" VerticalAlignment="Center" BorderThickness="2" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="ResultBadgeScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                    <Setter Property="BorderBrush" Value="#CBD5E1"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ScanTextResult}" Value="OK">
                                            <Setter Property="Background" Value="#ECFDF5"/>
                                            <Setter Property="BorderBrush" Value="#22C55E"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ScanTextResult}" Value="PASS">
                                            <Setter Property="Background" Value="#ECFDF5"/>
                                            <Setter Property="BorderBrush" Value="#22C55E"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ScanTextResult}" Value="NG">
                                            <Setter Property="Background" Value="#FEF2F2"/>
                                            <Setter Property="BorderBrush" Value="#DC2626"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontSize="56" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="•"/>
                                        <Setter Property="Foreground" Value="#94A3B8"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ScanTextResult}" Value="OK">
                                                <Setter Property="Text" Value="✓"/>
                                                <Setter Property="Foreground" Value="#16A34A"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ScanTextResult}" Value="PASS">
                                                <Setter Property="Text" Value="✓"/>
                                                <Setter Property="Foreground" Value="#16A34A"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ScanTextResult}" Value="NG">
                                                <Setter Property="Text" Value="!"/>
                                                <Setter Property="Foreground" Value="#DC2626"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Grid>

                    <TextBlock Margin="0,10,0,0" FontWeight="Black" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="NoWrap" RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <ScaleTransform x:Name="ResultTextScale" ScaleX="1" ScaleY="1"/>
                        </TextBlock.RenderTransform>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="CHỜ QUÉT"/>
                                <Setter Property="FontSize" Value="42"/>
                                <Setter Property="Foreground" Value="#64748B"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ScanTextResult}" Value="OK">
                                        <Setter Property="Text" Value="PASS"/>
                                        <Setter Property="FontSize" Value="68"/>
                                        <Setter Property="Foreground" Value="#16A34A"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ScanTextResult}" Value="PASS">
                                        <Setter Property="Text" Value="PASS"/>
                                        <Setter Property="FontSize" Value="68"/>
                                        <Setter Property="Foreground" Value="#16A34A"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ScanTextResult}" Value="NG">
                                        <Setter Property="Text" Value="NG"/>
                                        <Setter Property="FontSize" Value="76"/>
                                        <Setter Property="Foreground" Value="#DC2626"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <Border Grid.Row="4" CornerRadius="14" Padding="14,11" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ScanTextResult}" Value="OK">
                                    <Setter Property="Background" Value="#F0FDF4"/>
                                    <Setter Property="BorderBrush" Value="#BBF7D0"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ScanTextResult}" Value="PASS">
                                    <Setter Property="Background" Value="#F0FDF4"/>
                                    <Setter Property="BorderBrush" Value="#BBF7D0"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ScanTextResult}" Value="NG">
                                    <Setter Property="Background" Value="#FEF2F2"/>
                                    <Setter Property="BorderBrush" Value="#FECACA"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding ScanResultDetailText, NotifyOnTargetUpdated=True}"
                               FontSize="15.5"
                               FontWeight="Bold"
                               LineHeight="23"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               HorizontalAlignment="Stretch">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#64748B"/>
                                <Setter Property="Text" Value="Quét tem để xem kết quả PASS / NG."/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ScanTextResult}" Value="OK">
                                        <Setter Property="Foreground" Value="#166534"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ScanTextResult}" Value="PASS">
                                        <Setter Property="Foreground" Value="#166534"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ScanTextResult}" Value="NG">
                                        <Setter Property="Foreground" Value="#991B1B"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
