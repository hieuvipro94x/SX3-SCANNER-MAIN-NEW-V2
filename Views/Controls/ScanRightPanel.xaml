<UserControl x:Class="SX3_SCANER.Views.Controls.ScanRightPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Storyboard x:Key="ScanResultPulseStoryboard">
                <DoubleAnimation Storyboard.TargetName="ResultHaloScale"
                                 Storyboard.TargetProperty="ScaleX"
                                 From="0.72"
                                 To="1.55"
                                 Duration="0:0:0.55"
                                 AutoReverse="True"
                                 RepeatBehavior="2x"/>
                <DoubleAnimation Storyboard.TargetName="ResultHaloScale"
                                 Storyboard.TargetProperty="ScaleY"
                                 From="0.72"
                                 To="1.55"
                                 Duration="0:0:0.55"
                                 AutoReverse="True"
                                 RepeatBehavior="2x"/>
                <DoubleAnimation Storyboard.TargetName="ResultHalo"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0.58"
                                 To="0"
                                 Duration="0:0:0.55"
                                 AutoReverse="True"
                                 RepeatBehavior="2x"/>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ResultBadgeScale"
                                               Storyboard.TargetProperty="ScaleX">
                    <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.78"/>
                    <SplineDoubleKeyFrame KeyTime="0:0:0.16" Value="1.18"/>
                    <SplineDoubleKeyFrame KeyTime="0:0:0.34" Value="1"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ResultBadgeScale"
                                               Storyboard.TargetProperty="ScaleY">
                    <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.78"/>
                    <SplineDoubleKeyFrame KeyTime="0:0:0.16" Value="1.18"/>
                    <SplineDoubleKeyFrame KeyTime="0:0:0.34" Value="1"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ResultTextScale"
                                               Storyboard.TargetProperty="ScaleX">
                    <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.86"/>
                    <SplineDoubleKeyFrame KeyTime="0:0:0.14" Value="1.13"/>
                    <SplineDoubleKeyFrame KeyTime="0:0:0.30" Value="1"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ResultTextScale"
                                               Storyboard.TargetProperty="ScaleY">
                    <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.86"/>
                    <SplineDoubleKeyFrame KeyTime="0:0:0.14" Value="1.13"/>
                    <SplineDoubleKeyFrame KeyTime="0:0:0.30" Value="1"/>
                </DoubleAnimationUsingKeyFrames>
            </Storyboard>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Box progress -->
        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="THÙNG HIỆN TẠI" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="{Binding CurrentBoxNameText}" FontSize="20" FontWeight="Black" Foreground="{StaticResource TextMainBrush}" TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" CornerRadius="14" Padding="10,6" Background="{Binding CurrentBoxStatusBackground}" BorderBrush="{Binding CurrentBoxStatusBorderBrush}" BorderThickness="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentBoxStatusText}" FontSize="11" FontWeight="Black" Foreground="{Binding CurrentBoxStatusForeground}"/>
                    </Border>
                </Grid>
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="TIẾN ĐỘ" Style="{StaticResource FieldLabelStyle}" Foreground="{StaticResource OkBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding ScanQuantityText}" FontSize="17" FontWeight="Black" Foreground="{StaticResource TextMainBrush}"/>
                    </Grid>
                    <ProgressBar Grid.Row="2" Height="12" Minimum="0" Maximum="{Binding SelectedQuantity}" Value="{Binding CurrentScanProgress}" Foreground="{StaticResource OkBrush}" Background="#E2E8F0"/>
                </Grid>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="2" Columns="3">
            <Border CornerRadius="14" Background="#ECFDF5" BorderBrush="#BBF7D0" BorderThickness="1" Padding="10,8" Margin="0,0,5,0">
                <StackPanel>
                    <TextBlock Text="PASS" FontSize="11" FontWeight="Black" Foreground="{StaticResource OkBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentPassCount}" FontSize="24" FontWeight="Black" Foreground="{StaticResource TextMainBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border CornerRadius="14" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" Padding="10,8" Margin="5,0">
                <StackPanel>
                    <TextBlock Text="NG" FontSize="11" FontWeight="Black" Foreground="{StaticResource NgBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentNgCount}" FontSize="24" FontWeight="Black" Foreground="{StaticResource TextMainBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border CornerRadius="14" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" Padding="10,8" Margin="5,0,0,0">
                <StackPanel>
                    <TextBlock Text="HOÀN THÀNH" FontSize="10" FontWeight="Black" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentProgressPercentText}" FontSize="24" FontWeight="Black" Foreground="{StaticResource TextMainBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Latest scan result: light background, strong badge only -->
        <Border Grid.Row="4" Padding="20" MinHeight="280">
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ScanTextResult}" Value="OK">
                            <Setter Property="BorderBrush" Value="#22C55E"/>
                            <Setter Property="BorderThickness" Value="2"/>
                            <Setter Property="Background" Value="#F7FEFA"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ScanTextResult}" Value="PASS">
                            <Setter Property="BorderBrush" Value="#22C55E"/>
                            <Setter Property="BorderThickness" Value="2"/>
                            <Setter Property="Background" Value="#F7FEFA"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ScanTextResult}" Value="NG">
                            <Setter Property="BorderBrush" Value="#DC2626"/>
                            <Setter Property="BorderThickness" Value="2"/>
                            <Setter Property="Background" Value="#FFF7F7"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.14" Color="#334155"/>
            </Border.Effect>
            <Grid>
                <Grid.Triggers>
                    <EventTrigger RoutedEvent="Binding.TargetUpdated">
                        <BeginStoryboard Storyboard="{StaticResource ScanResultPulseStoryboard}"/>
                    </EventTrigger>
                </Grid.Triggers>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="KẾT QUẢ SCAN MỚI NHẤT" Style="{StaticResource SectionTitleStyle}" HorizontalAlignment="Center"/>

                <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Grid Width="136" Height="136" HorizontalAlignment="Center">
                        <Ellipse x:Name="ResultHalo"
                                 Width="118"
                                 Height="118"
                                 Opacity="0"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="ResultHaloScale" ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#CBD5E1"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ScanTextResult}" Value="OK"><Setter Property="Fill" Value="#86EFAC"/></DataTrigger>
                                        <DataTrigger Binding="{Binding ScanTextResult}" Value="PASS"><Setter Property="Fill" Value="#86EFAC"/></DataTrigger>
                                        <DataTrigger Binding="{Binding ScanTextResult}" Value="NG"><Setter Property="Fill" Value="#FCA5A5"/></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    <Border Width="106" Height="106" CornerRadius="53" HorizontalAlignment="Center" VerticalAlignment="Center" BorderThickness="2" RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="ResultBadgeScale" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#F1F5F9"/>
                                <Setter Property="BorderBrush" Value="#CBD5E1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ScanTextResult}" Value="OK"><Setter Property="Background" Value="#ECFDF5"/><Setter Property="BorderBrush" Value="#22C55E"/></DataTrigger>
                                    <DataTrigger Binding="{Binding ScanTextResult}" Value="PASS"><Setter Property="Background" Value="#ECFDF5"/><Setter Property="BorderBrush" Value="#22C55E"/></DataTrigger>
                                    <DataTrigger Binding="{Binding ScanTextResult}" Value="NG"><Setter Property="Background" Value="#FEF2F2"/><Setter Property="BorderBrush" Value="#DC2626"/></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="56" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="•"/>
                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ScanTextResult}" Value="OK"><Setter Property="Text" Value="✓"/><Setter Property="Foreground" Value="#16A34A"/></DataTrigger>
                                        <DataTrigger Binding="{Binding ScanTextResult}" Value="PASS"><Setter Property="Text" Value="✓"/><Setter Property="Foreground" Value="#16A34A"/></DataTrigger>
                                        <DataTrigger Binding="{Binding ScanTextResult}" Value="NG"><Setter Property="Text" Value="!"/><Setter Property="Foreground" Value="#DC2626"/></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    </Grid>

                    <TextBlock Margin="0,10,0,0" FontWeight="Black" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="NoWrap" RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <ScaleTransform x:Name="ResultTextScale" ScaleX="1" ScaleY="1"/>
                        </TextBlock.RenderTransform>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="CHỜ QUÉT"/>
                                <Setter Property="FontSize" Value="42"/>
                                <Setter Property="Foreground" Value="#64748B"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ScanTextResult}" Value="OK"><Setter Property="Text" Value="PASS"/><Setter Property="FontSize" Value="68"/><Setter Property="Foreground" Value="#16A34A"/></DataTrigger>
                                    <DataTrigger Binding="{Binding ScanTextResult}" Value="PASS"><Setter Property="Text" Value="PASS"/><Setter Property="FontSize" Value="68"/><Setter Property="Foreground" Value="#16A34A"/></DataTrigger>
                                    <DataTrigger Binding="{Binding ScanTextResult}" Value="NG"><Setter Property="Text" Value="NG"/><Setter Property="FontSize" Value="76"/><Setter Property="Foreground" Value="#DC2626"/></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <Border Grid.Row="4" CornerRadius="14" Padding="14,11" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ScanTextResult}" Value="OK"><Setter Property="Background" Value="#F0FDF4"/><Setter Property="BorderBrush" Value="#BBF7D0"/></DataTrigger>
                                <DataTrigger Binding="{Binding ScanTextResult}" Value="PASS"><Setter Property="Background" Value="#F0FDF4"/><Setter Property="BorderBrush" Value="#BBF7D0"/></DataTrigger>
                                <DataTrigger Binding="{Binding ScanTextResult}" Value="NG"><Setter Property="Background" Value="#FEF2F2"/><Setter Property="BorderBrush" Value="#FECACA"/></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding ScanResultDetailText, NotifyOnTargetUpdated=True}"
                               FontSize="15.5"
                               FontWeight="Bold"
                               LineHeight="23"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               HorizontalAlignment="Stretch">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#64748B"/>
                                <Setter Property="Text" Value="Quét tem để xem kết quả PASS / NG."/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ScanTextResult}" Value="OK"><Setter Property="Foreground" Value="#166534"/></DataTrigger>
                                    <DataTrigger Binding="{Binding ScanTextResult}" Value="PASS"><Setter Property="Foreground" Value="#166534"/></DataTrigger>
                                    <DataTrigger Binding="{Binding ScanTextResult}" Value="NG"><Setter Property="Foreground" Value="#991B1B"/></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
