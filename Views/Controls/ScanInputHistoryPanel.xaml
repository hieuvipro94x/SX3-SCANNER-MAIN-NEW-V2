<UserControl x:Class="SX3_SCANER.Views.Controls.ScanInputHistoryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:SX3_SCANER"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodel="clr-namespace:SX3_SCANER.ViewModel"
             d:DataContext="{d:DesignInstance Type=viewmodel:MainViewModel}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
<Grid Grid.Row="1"
      Grid.Column="1"
      Margin="4,4">
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <!-- MÃ QR MẪU / EXPECTED -->
        <Border Grid.Row="0"
        CornerRadius="14"
        Background="#FFFBEB"
        BorderBrush="#F59E0B"
        BorderThickness="1.5"
        Padding="14,10">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="MÃ QR YÊU CẦU"
   FontSize="14"
   FontWeight="Bold"
   Foreground="#B45309"/>

                <TextBlock Grid.Row="2"
   d:Text="WH3224652605120001"
   Text="{Binding FullCodeExpected}"
   FontSize="18"
   FontWeight="Bold"
   Foreground="#0F172A"
   TextAlignment="Center"
   HorizontalAlignment="Stretch"
   TextWrapping="Wrap"/>
            </Grid>
        </Border>


        <!-- NHẬP MÃ SCAN -->
        <Border Grid.Row="2"
        CornerRadius="14"
        Background="White"
        BorderBrush="#CBD5E1"
        BorderThickness="1.5"
        Padding="10">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="96"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="TbxInputCode"
 Grid.Column="0"
 Height="56"
 FontSize="20"
 d:Text="THIS IS THE TEXTBOX INPUT SCAN DATA"
 Text="{Binding InputScanCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
 TextAlignment="Center"
 VerticalContentAlignment="Center"
 FontWeight="Bold"
 Foreground="#020617"
 Background="#F8FAFC"
 BorderBrush="#2563EB"
 BorderThickness="3">
                    <TextBox.InputBindings>
                        <KeyBinding Gesture="Enter"
            Command="{Binding InputScanCodeCMD}"
            CommandParameter="{Binding ElementName=TbxInputCode, Path=Text}" />
                    </TextBox.InputBindings>
                </TextBox>
                    <Button Grid.Column="2"
        Height="56"
        Width="90"
        Padding="0"
        Margin="6,0,0,0"
        HorizontalAlignment="Right"
        VerticalAlignment="Center"
        Foreground="White"
        BorderThickness="0"
        Command="{Binding STARTCMD}"
        CommandParameter="{Binding ElementName=TbxInputCode}"
        ToolTip="Bắt đầu / Dừng phiên scan"
        Cursor="Hand"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#16A34A"/>
                                <Setter Property="Opacity" Value="1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding BtnSTART_CONTENT}" Value="STOP">
                                        <Setter Property="Background" Value="#DC2626"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding BtnSTART_CONTENT}" Value="DỪNG">
                                        <Setter Property="Background" Value="#DC2626"/>
                                    </DataTrigger>

                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.94"/>
                                    </Trigger>

                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Opacity" Value="0.86"/>
                                    </Trigger>

                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.45"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="MainBorder"
                    Width="{TemplateBinding Width}"
                    Height="{TemplateBinding Height}"
                    CornerRadius="12"
                    Background="{TemplateBinding Background}"
                    BorderThickness="1"
                    BorderBrush="#BBF7D0"
                    SnapsToDevicePixels="True">

                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10"
                                      ShadowDepth="0"
                                      Color="#16A34A"
                                      Opacity="0.28"/>
                                    </Border.Effect>

                                    <Grid ClipToBounds="True">
                                        <Border CornerRadius="12"
                            Height="24"
                            VerticalAlignment="Top"
                            Background="White"
                            Opacity="0.16"/>

                                        <Grid HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="26"/>
                                                <RowDefinition Height="18"/>
                                            </Grid.RowDefinitions>

                                            <Border Grid.Row="0"
                                Width="26"
                                Height="26"
                                CornerRadius="13"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="White">

                                                <materialDesign:PackIcon Width="18"
                                                     Height="18"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     Foreground="{TemplateBinding Background}">
                                                    <materialDesign:PackIcon.Style>
                                                        <Style TargetType="materialDesign:PackIcon">
                                                            <Setter Property="Kind" Value="PlayCircle"/>

                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding BtnSTART_CONTENT}" Value="STOP">
                                                                    <Setter Property="Kind" Value="StopCircle"/>
                                                                </DataTrigger>

                                                                <DataTrigger Binding="{Binding BtnSTART_CONTENT}" Value="DỪNG">
                                                                    <Setter Property="Kind" Value="StopCircle"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </materialDesign:PackIcon.Style>
                                                </materialDesign:PackIcon>
                                            </Border>

                                            <TextBlock Grid.Row="1"
                                   Text="{Binding BtnSTART_CONTENT}"
                                   FontSize="12"
                                   FontWeight="Black"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"/>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding BtnSTART_CONTENT}" Value="STOP">
                                        <Setter TargetName="MainBorder" Property="BorderBrush" Value="#FECACA"/>
                                        <Setter TargetName="MainBorder" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="10"
                                              ShadowDepth="0"
                                              Color="#DC2626"
                                              Opacity="0.28"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding BtnSTART_CONTENT}" Value="DỪNG">
                                        <Setter TargetName="MainBorder" Property="BorderBrush" Value="#FECACA"/>
                                        <Setter TargetName="MainBorder" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="10"
                                              ShadowDepth="0"
                                              Color="#DC2626"
                                              Opacity="0.28"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>

                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="MainBorder" Property="BorderBrush" Value="White"/>
                                    </Trigger>

                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="MainBorder" Property="RenderTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter TargetName="MainBorder" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                    </Trigger>

                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="MainBorder" Property="Effect" Value="{x:Null}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
        </Border>
    </Grid>

    <Border Grid.Row="1" Margin="4,8,4,0" CornerRadius="14" Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
        <DataGrid
      ItemsSource="{Binding ScanHistoryView}"
      IsReadOnly="True"
      AutoGenerateColumns="True"
      AutoGeneratingColumn="HideRowIndex_AutoGeneratingColumn"
      LoadingRow="DataGrid_LoadingRow"
      FontSize="11"
      RowHeight="28"
      ColumnHeaderHeight="30"
      HeadersVisibility="All"
      GridLinesVisibility="Horizontal"
      CanUserAddRows="False"
      CanUserDeleteRows="False"
      CanUserResizeRows="False"
      CanUserResizeColumns="False"
      CanUserSortColumns="False"
      HorizontalScrollBarVisibility="Visible"
      VerticalScrollBarVisibility="Auto"
      ScrollViewer.HorizontalScrollBarVisibility="Visible"
      ScrollViewer.VerticalScrollBarVisibility="Auto"
      ScrollViewer.CanContentScroll="True"
      EnableRowVirtualization="True"
      EnableColumnVirtualization="True"
      VirtualizingPanel.IsVirtualizing="True"
      VirtualizingPanel.VirtualizationMode="Recycling"
      ColumnWidth="SizeToCells"
      MinColumnWidth="82"
      Background="White"
      ColumnHeaderStyle="{StaticResource UnifiedScanDataGridColumnHeaderStyle}"
      RowStyle="{StaticResource UnifiedScanRowStyle}"
      BorderThickness="0" Margin="0">

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="3,0"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                    <Setter Property="TextBlock.TextWrapping" Value="NoWrap"/>
                </Style>
            </DataGrid.CellStyle>

        </DataGrid>
    </Border>
</Grid>
</UserControl>
