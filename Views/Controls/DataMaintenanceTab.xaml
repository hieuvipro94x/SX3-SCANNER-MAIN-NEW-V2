<UserControl x:Class="SX3_SCANER.Views.Controls.DataMaintenanceTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="650"
             d:DesignWidth="1180"
             Background="#F8FAFC">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <materialDesign:Card Padding="18" UniformCornerRadius="12" Background="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="BẢO TRÌ DỮ LIỆU / BACKUP / RESTORE"
                                   FontSize="22"
                                   FontWeight="Black"
                                   Foreground="#0F172A"/>
                        <TextBlock Margin="0,6,0,0"
                                   Text="Tối ưu để dữ liệu lớn vẫn chạy nhanh, tự backup mỗi ngày và tránh mất dữ liệu khi máy lỗi ổ cứng."
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#475569"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Height="40"
                            MinWidth="130"
                            Command="{Binding RefreshMaintenanceInfoCMD}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            ToolTip="Cập nhật lại dung lượng và trạng thái backup">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" Margin="0,0,6,0"/>
                            <TextBlock Text="LÀM MỚI" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </materialDesign:Card>

            <Grid Grid.Row="1" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <materialDesign:Card Grid.Column="0" Padding="18" UniformCornerRadius="12" Background="White">
                    <StackPanel>
                        <TextBlock Text="THÔNG TIN DATABASE"
                                   FontSize="17"
                                   FontWeight="Black"
                                   Foreground="#0F172A"/>

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="database.db" FontWeight="Bold" Foreground="#475569"/>
                            <TextBlock Grid.Column="1" Text="{Binding DatabaseSizeText}" FontWeight="Black" Foreground="#2563EB"/>

                            <TextBlock Grid.Row="1" Margin="0,10,0,0" Text="product.db" FontWeight="Bold" Foreground="#475569"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Text="{Binding ProductDatabaseSizeText}" FontWeight="Black" Foreground="#2563EB"/>

                            <TextBlock Grid.Row="2" Margin="0,10,0,0" Text="Đường dẫn DB" FontWeight="Bold" Foreground="#475569"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Margin="0,6,0,0" Text="{Binding DatabasePathText}" IsReadOnly="True" FontSize="12"/>

                            <TextBlock Grid.Row="3" Margin="0,10,0,0" Text="Backup local" FontWeight="Bold" Foreground="#475569"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Margin="0,6,0,0" Text="{Binding BackupLocalDirectoryText}" IsReadOnly="True" FontSize="12"/>
                        </Grid>

                        <Border Margin="0,16,0,0" Padding="12" CornerRadius="10" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1">
                            <TextBlock Text="Gợi ý: backup local giúp khôi phục nhanh, nhưng vẫn nên nhập thêm thư mục mạng/NAS/server để phòng máy scan hỏng ổ cứng."
                                       TextWrapping="Wrap"
                                       FontWeight="SemiBold"
                                       Foreground="#1E3A8A"/>
                        </Border>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Grid.Column="2" Padding="18" UniformCornerRadius="12" Background="White">
                    <StackPanel>
                        <TextBlock Text="CẤU HÌNH BACKUP TỰ ĐỘNG"
                                   FontSize="17"
                                   FontWeight="Black"
                                   Foreground="#0F172A"/>

                        <CheckBox Margin="0,14,0,0"
                                  Content="Bật backup tự động mỗi ngày"
                                  IsChecked="{Binding BackupEnabled}"
                                  FontSize="14"
                                  FontWeight="Bold"/>

                        <TextBlock Margin="0,14,0,4" Text="Thư mục mạng / server / NAS" FontWeight="Bold" Foreground="#475569"/>
                        <TextBox Height="38"
                                 Text="{Binding BackupNetworkDirectoryText, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Ví dụ: \\192.168.1.100\SX3Backup"/>

                        <TextBlock Margin="0,14,0,4" Text="Số ngày giữ backup" FontWeight="Bold" Foreground="#475569"/>
                        <TextBox Width="120"
                                 HorizontalAlignment="Left"
                                 Height="38"
                                 Text="{Binding BackupRetentionDaysText, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="30"/>

                        <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                            <Button Height="40" MinWidth="120" Margin="0,0,10,0"
                                    Command="{Binding SaveBackupSettingsCMD}"
                                    Style="{StaticResource MaterialDesignRaisedButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18" Margin="0,0,6,0"/>
                                    <TextBlock Text="LƯU" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>

                            <Button Height="40" MinWidth="150" Margin="0,0,10,0"
                                    Command="{Binding RunBackupNowCMD}"
                                    Style="{StaticResource MaterialDesignRaisedButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Database" Width="18" Height="18" Margin="0,0,6,0"/>
                                    <TextBlock Text="BACKUP NGAY" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>

                            <Button Height="40" MinWidth="145"
                                    Command="{Binding RestoreBackupCMD}"
                                    Background="#DC2626"
                                    Foreground="White"
                                    BorderBrush="#B91C1C"
                                    Style="{StaticResource MaterialDesignRaisedButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="BackupRestore" Width="18" Height="18" Margin="0,0,6,0"/>
                                    <TextBlock Text="RESTORE" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>
            </Grid>

            <materialDesign:Card Grid.Row="2" Margin="0,16,0,0" Padding="18" UniformCornerRadius="12" Background="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Lần backup cuối" FontWeight="Black" Foreground="#475569"/>
                    <TextBlock Grid.Column="1" Text="{Binding LastBackupText}" FontWeight="Black" Foreground="#0F172A"/>

                    <TextBlock Grid.Row="1" Margin="0,12,0,0" Text="Trạng thái backup" FontWeight="Black" Foreground="#475569"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" Text="{Binding BackupStatusText}" TextWrapping="Wrap" FontWeight="SemiBold" Foreground="#334155"/>

                    <TextBlock Grid.Row="2" Margin="0,12,0,0" Text="Trạng thái màn hình" FontWeight="Black" Foreground="#475569"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" Text="{Binding MaintenanceStatus}" TextWrapping="Wrap" FontWeight="SemiBold" Foreground="#2563EB"/>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </ScrollViewer>
</UserControl>
