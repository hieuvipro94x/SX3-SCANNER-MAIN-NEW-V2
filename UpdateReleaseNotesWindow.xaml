<Window x:Class="SX3_SCANER.UpdateReleaseNotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SX3 Scanner - Chi tiết bản cập nhật"
        Width="1180"
        Height="820"
        MinWidth="960"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#EEF2F7"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#1D4ED8"/>
        <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#1E40AF"/>
        <SolidColorBrush x:Key="TextMainBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#DCE3EC"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#F8FAFC"/>

        <Style x:Key="BaseRoundedButton" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="MinWidth" Value="138"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="13"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.16" Color="#334155"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.985" ScaleY="0.985"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ButtonBorder" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseRoundedButton}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryHoverBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryPressedBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryPressedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource BaseRoundedButton}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFC"/>
                    <Setter Property="BorderBrush" Value="#94A3B8"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#EEF2F7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,5,0,0"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="TextTrimming" Value="None"/>
        </Style>

        <Style x:Key="InfoTile" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="15,13"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Border Background="White"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="22"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28" ShadowDepth="2" Opacity="0.14" Color="#0F172A"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0"
                        CornerRadius="22,22,0,0"
                        Padding="24,22,24,18">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#EFF6FF" Offset="0"/>
                            <GradientStop Color="#FFFFFF" Offset="0.58"/>
                            <GradientStop Color="#F8FAFC" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="58"
                                Height="58"
                                CornerRadius="17"
                                VerticalAlignment="Top">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#2563EB" Offset="0"/>
                                    <GradientStop Color="#0EA5E9" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.28" Color="#2563EB"/>
                            </Border.Effect>
                            <TextBlock Text="SX3"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="White"
                                       FontSize="15"
                                       FontWeight="Black"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="17,0,18,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Có bản cập nhật mới"
                                           Foreground="{StaticResource TextMainBrush}"
                                           FontSize="27"
                                           FontWeight="Black"
                                           TextWrapping="Wrap"/>
                                <Border x:Name="RequiredBadge"
                                        Margin="12,4,0,4"
                                        Padding="10,4"
                                        Background="#FEF2F2"
                                        BorderBrush="#FECACA"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Visibility="Collapsed">
                                    <TextBlock Text="BẮT BUỘC"
                                               Foreground="#B91C1C"
                                               FontSize="11"
                                               FontWeight="Black"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Margin="0,5,0,0"
                                       Text="Vui lòng kiểm tra nội dung thay đổi trước khi cài đặt để tránh gián đoạn quá trình scan."
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <Border Grid.Column="2"
                                Padding="13,7"
                                VerticalAlignment="Top"
                                Background="#DBEAFE"
                                BorderBrush="#BFDBFE"
                                BorderThickness="1"
                                CornerRadius="14">
                            <TextBlock Text="GITHUB RELEASE"
                                       Foreground="#1D4ED8"
                                       FontSize="12"
                                       FontWeight="Black"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Update information -->
                <Border Grid.Row="1"
                        Margin="24,0,24,16"
                        Padding="16"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" MinWidth="150"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="1*" MinWidth="150"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="1*" MinWidth="150"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource InfoTile}">
                                <StackPanel>
                                    <TextBlock Text="Phiên bản hiện tại" Style="{StaticResource InfoLabel}"/>
                                    <TextBlock x:Name="txtCurrentVersion"
                                               Margin="0,4,0,0"
                                               Foreground="#475569"
                                               FontSize="23"
                                               FontWeight="Black"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource InfoTile}" BorderBrush="#FED7AA" Background="#FFF7ED">
                                <StackPanel>
                                    <TextBlock Text="Phiên bản mới" Style="{StaticResource InfoLabel}" Foreground="#9A3412"/>
                                    <TextBlock x:Name="txtNewVersion"
                                               Margin="0,4,0,0"
                                               Foreground="#EA580C"
                                               FontSize="25"
                                               FontWeight="Black"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="4" Style="{StaticResource InfoTile}" BorderBrush="#BBF7D0" Background="#F0FDF4">
                                <StackPanel>
                                    <TextBlock Text="Trạng thái bảo mật" Style="{StaticResource InfoLabel}" Foreground="#166534"/>
                                    <TextBlock Margin="0,6,0,0"
                                               Text="✓ Đã xác thực SHA256"
                                               Foreground="#15803D"
                                               FontSize="15"
                                               FontWeight="Black"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" MinWidth="280"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="1*" MinWidth="180"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="2*" MinWidth="280"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource InfoTile}">
                                <StackPanel>
                                    <TextBlock Text="File cập nhật" Style="{StaticResource InfoLabel}"/>
                                    <TextBlock x:Name="txtFileName" Style="{StaticResource InfoValue}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource InfoTile}">
                                <StackPanel>
                                    <TextBlock Text="Dung lượng" Style="{StaticResource InfoLabel}"/>
                                    <TextBlock x:Name="txtFileSize" Style="{StaticResource InfoValue}" FontSize="16"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="4" Style="{StaticResource InfoTile}">
                                <StackPanel>
                                    <TextBlock Text="Nguồn phát hành" Style="{StaticResource InfoLabel}"/>
                                    <TextBlock x:Name="txtReleaseSource"
                                               Style="{StaticResource InfoValue}"
                                               Foreground="#2563EB"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Release notes -->
                <Border Grid.Row="2"
                        Margin="24,0,24,0"
                        Background="White"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        CornerRadius="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Padding="18,13"
                                Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="0,0,0,1"
                                CornerRadius="18,18,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="5"
                                            Height="24"
                                            Margin="0,0,11,0"
                                            Background="{StaticResource PrimaryBrush}"
                                            CornerRadius="3"/>
                                    <StackPanel>
                                        <TextBlock Text="Nội dung thay đổi"
                                                   Foreground="{StaticResource TextMainBrush}"
                                                   FontSize="17"
                                                   FontWeight="Black"/>
                                        <TextBlock Text="Các mục mới, lỗi đã sửa và lưu ý khi cập nhật."
                                                   Margin="0,2,0,0"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="12.5"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Padding="10,5"
                                        VerticalAlignment="Center"
                                        Background="#EEF2FF"
                                        BorderBrush="#C7D2FE"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <TextBlock Text="MARKDOWN"
                                               Foreground="#4338CA"
                                               FontSize="11"
                                               FontWeight="Black"/>
                                </Border>
                            </Grid>
                        </Border>

                        <FlowDocumentScrollViewer x:Name="releaseNotesViewer"
                                                  Grid.Row="1"
                                                  Padding="30,24"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  IsSelectionEnabled="True"
                                                  IsToolBarVisible="False"
                                                  VerticalScrollBarVisibility="Auto">
                            <FlowDocument x:Name="releaseNotesDocument"
                                          PagePadding="0"
                                          ColumnWidth="100000"
                                          FontFamily="Segoe UI"
                                          FontSize="16.5"
                                          Foreground="#1E293B"
                                          LineHeight="29"
                                          TextAlignment="Left"/>
                        </FlowDocumentScrollViewer>
                    </Grid>
                </Border>

                <!-- Footer -->
                <Border Grid.Row="3"
                        Margin="24,16,24,20"
                        Padding="15,14"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Sau khi xác nhận, ứng dụng sẽ đóng và mở trình cài đặt bản mới."
                                       Foreground="{StaticResource TextMainBrush}"
                                       FontSize="13.5"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="Hãy lưu công việc đang làm trước khi cập nhật."
                                       Margin="0,3,0,0"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="12.5"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Width="128"
                                Margin="18,0,12,0"
                                Content="Để sau"
                                Click="Cancel_Click"
                                IsCancel="True"
                                Style="{StaticResource SecondaryButton}"/>

                        <Button Grid.Column="2"
                                Width="178"
                                Content="Cập nhật ngay"
                                Click="Update_Click"
                                IsDefault="True"
                                Style="{StaticResource PrimaryButton}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
