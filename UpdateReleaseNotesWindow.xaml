<Window x:Class="SX3_SCANER.UpdateReleaseNotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SX3 Scanner - Chi tiết bản cập nhật"
        Width="1120"
        Height="840"
        MinWidth="900"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#EEF2F7"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="12.5"/>
        </Style>

        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Border Background="White"
                BorderBrush="#DCE3EC"
                BorderThickness="1"
                CornerRadius="18"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24"
                                  ShadowDepth="3"
                                  Opacity="0.13"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Height="5"
                        VerticalAlignment="Top"
                        Background="#2563EB"
                        CornerRadius="18,18,0,0"/>

                <Grid Grid.Row="0" Margin="28,25,28,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="52"
                            Height="52"
                            Background="#EFF6FF"
                            CornerRadius="14">
                        <TextBlock Text="↑"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#2563EB"
                                   FontSize="28"
                                   FontWeight="Bold"/>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="16,0,20,0">
                        <TextBlock Text="Có bản cập nhật mới"
                                   Foreground="#0F172A"
                                   FontSize="27"
                                   FontWeight="Bold"/>
                        <TextBlock Margin="0,4,0,0"
                                   Text="Xem toàn bộ nội dung thay đổi trước khi cài đặt."
                                   Foreground="#64748B"
                                   FontSize="14"/>
                    </StackPanel>

                    <Border Grid.Column="2"
                            Padding="13,7"
                            VerticalAlignment="Top"
                            Background="#EFF6FF"
                            BorderBrush="#BFDBFE"
                            BorderThickness="1"
                            CornerRadius="14">
                        <TextBlock Text="GitHub Release"
                                   Foreground="#1D4ED8"
                                   FontWeight="SemiBold"/>
                    </Border>
                </Grid>

                <Border Grid.Row="1"
                        Margin="28,0,28,18"
                        Padding="18"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Phiên bản hiện tại"
                                       Style="{StaticResource InfoLabel}"/>
                            <TextBlock x:Name="txtCurrentVersion"
                                       Margin="0,3,0,0"
                                       Foreground="#475569"
                                       FontSize="21"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Phiên bản mới"
                                       Style="{StaticResource InfoLabel}"/>
                            <StackPanel Margin="0,3,0,0"
                                        Orientation="Horizontal">
                                <TextBlock x:Name="txtNewVersion"
                                           Foreground="#EA580C"
                                           FontSize="23"
                                           FontWeight="Bold"/>
                                <Border x:Name="RequiredBadge"
                                        Margin="10,2,0,2"
                                        Padding="8,2"
                                        Background="#FEF2F2"
                                        CornerRadius="8">
                                    <TextBlock Text="Bắt buộc"
                                               Foreground="#B91C1C"
                                               FontSize="11"
                                               FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Column="2"
                                Margin="0,0,18,0"
                                Background="#E2E8F0"/>

                        <StackPanel Grid.Column="3" Margin="0,0,20,0">
                            <TextBlock Text="File cập nhật"
                                       Style="{StaticResource InfoLabel}"/>
                            <TextBlock x:Name="txtFileName"
                                       Style="{StaticResource InfoValue}"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="Nguồn phát hành"
                                       Style="{StaticResource InfoLabel}"/>
                            <TextBlock x:Name="txtReleaseSource"
                                       Style="{StaticResource InfoValue}"
                                       Foreground="#2563EB"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Dung lượng"
                                       Style="{StaticResource InfoLabel}"/>
                            <TextBlock x:Name="txtFileSize"
                                       Style="{StaticResource InfoValue}"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="Trạng thái"
                                       Style="{StaticResource InfoLabel}"/>
                            <TextBlock Margin="0,4,0,0"
                                       Text="Đã xác thực SHA256"
                                       Foreground="#15803D"
                                       FontSize="14"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Margin="28,0,28,0"
                        Background="White"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        CornerRadius="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Padding="18,12"
                                Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="0,0,0,1"
                                CornerRadius="14,14,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal">
                                    <Border Width="4"
                                            Height="22"
                                            Margin="0,0,10,0"
                                            Background="#2563EB"
                                            CornerRadius="2"/>
                                    <TextBlock Text="Nội dung thay đổi"
                                               VerticalAlignment="Center"
                                               Foreground="#0F172A"
                                               FontSize="17"
                                               FontWeight="Bold"/>
                                </StackPanel>

                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Text="Markdown"
                                           Foreground="#64748B"
                                           FontSize="12.5"/>
                            </Grid>
                        </Border>

                        <FlowDocumentScrollViewer x:Name="releaseNotesViewer"
                                                  Grid.Row="1"
                                                  Padding="24,20"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  IsSelectionEnabled="True"
                                                  IsToolBarVisible="False"
                                                  VerticalScrollBarVisibility="Auto">
                            <FlowDocument x:Name="releaseNotesDocument"
                                          PagePadding="0"
                                          ColumnWidth="100000"
                                          FontFamily="Segoe UI"
                                          FontSize="15"
                                          Foreground="#1E293B"
                                          LineHeight="25"/>
                        </FlowDocumentScrollViewer>
                    </Grid>
                </Border>

                <Grid Grid.Row="3" Margin="28,18,28,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock VerticalAlignment="Center"
                               Text="Ứng dụng sẽ đóng và mở trình cài đặt sau khi bạn xác nhận."
                               Foreground="#64748B"
                               FontSize="13.5"
                               TextWrapping="Wrap"/>

                    <Button Grid.Column="1"
                            Width="120"
                            Margin="16,0,12,0"
                            Content="Để sau"
                            Click="Cancel_Click"
                            IsCancel="True"
                            Style="{StaticResource SecondaryButton}"/>

                    <Button Grid.Column="2"
                            Width="170"
                            Content="Cập nhật ngay"
                            Click="Update_Click"
                            IsDefault="True"
                            Style="{StaticResource PrimaryButton}"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
