<Window x:Class="SX3_SCANER.View.ScanErrorWD"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kết quả scan: NG"
        Width="760"
        Height="520"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="WarningLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="Margin" Value="0,4,16,4"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <Style x:Key="WarningValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="28"/>
        </Style>
    </Window.Resources>

    <Border Margin="16"
            Padding="24"
            Background="#FFF7F7"
            BorderBrush="#DC2626"
            BorderThickness="4"
            CornerRadius="24">
        <Border.Effect>
            <DropShadowEffect Color="#7F1D1D"
                              BlurRadius="26"
                              ShadowDepth="5"
                              Opacity="0.34"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="76"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <Border Background="#DC2626"
                    CornerRadius="14">
                <TextBlock Text="KẾT QUẢ SCAN: NG"
                           FontSize="42"
                           FontWeight="Black"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center"/>
            </Border>

            <Grid Grid.Row="1"
                  Margin="8,10,8,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="174"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Chi tiết lỗi" Style="{StaticResource WarningLabelStyle}" Height="32" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DetailText"
                           Foreground="#B91C1C" FontWeight="Bold"
                           Style="{StaticResource WarningValueStyle}" Margin="0,4,0,4"/>

                <TextBlock Grid.Row="1" Text="Tiêu chuẩn" Style="{StaticResource WarningLabelStyle}" Height="32" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="StandardText"
                           Style="{StaticResource WarningValueStyle}" Margin="0,4,0,4"/>

                <TextBlock Grid.Row="2" Text="Thực tế" Style="{StaticResource WarningLabelStyle}" Height="32" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="ActualText"
                           Foreground="#B91C1C" FontWeight="Bold"
                           Style="{StaticResource WarningValueStyle}" Margin="0,4,0,4"/>

                <TextBlock Grid.Row="3" Text="Cần xác nhận" Style="{StaticResource WarningLabelStyle}" Height="32" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="ResolutionText"
                           Style="{StaticResource WarningValueStyle}" Margin="0,4,0,4"/>
            </Grid>

            <Button Grid.Row="2"
                    Content="ĐÃ HIỂU"
                    Width="240"
                    Height="58"
                    FontSize="24"
                    FontWeight="Black"
                    Foreground="White"
                    Background="#DC2626"
                    BorderThickness="0"
                    HorizontalAlignment="Center"
                    IsDefault="True"
                    Click="Close_Click"/>
        </Grid>
    </Border>

</Window>
