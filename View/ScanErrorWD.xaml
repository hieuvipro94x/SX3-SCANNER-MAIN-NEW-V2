<Window x:Class="SX3_SCANER.View.ScanErrorWD"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kết quả scan: NG"
        Width="760"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="DialogLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="DialogValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="25"/>
        </Style>
    </Window.Resources>

    <Border Margin="18" Padding="0" Background="White" BorderBrush="#DC2626" BorderThickness="1.5" CornerRadius="24">
        <Border.Effect>
            <DropShadowEffect Color="#334155" BlurRadius="30" ShadowDepth="0" Opacity="0.28"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#FEF2F2" CornerRadius="24,24,0,0" Padding="24,20" BorderBrush="#FECACA" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="58" Height="58" CornerRadius="29" Background="#DC2626" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <TextBlock Text="!" FontSize="36" FontWeight="Black" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="KẾT QUẢ SCAN: NG" FontSize="30" FontWeight="Black" Foreground="#991B1B"/>
                        <TextBlock Text="Tem không đạt điều kiện kiểm tra. Xem rõ tiêu chuẩn và dữ liệu thực tế bên dưới." FontSize="14" FontWeight="SemiBold" Foreground="#7F1D1D" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="24,22,24,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" CornerRadius="14" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" Padding="14,12">
                    <StackPanel>
                        <TextBlock Text="CHI TIẾT LỖI" Style="{StaticResource DialogLabelStyle}" Foreground="#B91C1C"/>
                        <TextBlock x:Name="DetailText" Style="{StaticResource DialogValueStyle}" Foreground="#991B1B" FontWeight="Black"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" CornerRadius="14" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="14,12">
                    <StackPanel>
                        <TextBlock Text="TIÊU CHUẨN" Style="{StaticResource DialogLabelStyle}"/>
                        <TextBlock x:Name="StandardText" Style="{StaticResource DialogValueStyle}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="4" CornerRadius="14" Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1" Padding="14,12">
                    <StackPanel>
                        <TextBlock Text="THỰC TẾ" Style="{StaticResource DialogLabelStyle}" Foreground="#C2410C"/>
                        <TextBlock x:Name="ActualText" Style="{StaticResource DialogValueStyle}" Foreground="#C2410C" FontWeight="Black"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="6" CornerRadius="14" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" Padding="14,12">
                    <StackPanel>
                        <TextBlock Text="CẦN XÁC NHẬN" Style="{StaticResource DialogLabelStyle}" Foreground="#1D4ED8"/>
                        <TextBlock x:Name="ResolutionText" Style="{StaticResource DialogValueStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="#F8FAFC" CornerRadius="0,0,24,24" Padding="24,16" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                <Button Content="ĐÃ HIỂU - QUAY LẠI SCAN" Width="280" Height="50" FontSize="16" FontWeight="Black" Foreground="White" Background="#DC2626" BorderThickness="0" HorizontalAlignment="Center" IsDefault="True" Click="Close_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="14" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Border>
        </Grid>
    </Border>
</Window>
