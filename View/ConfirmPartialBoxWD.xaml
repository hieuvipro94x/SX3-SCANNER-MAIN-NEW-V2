<Window x:Class="SX3_SCANER.View.ConfirmPartialBoxWD"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Xác nhận đóng thùng lẻ"
        Width="760"
        Height="520"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="WarningLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="Margin" Value="0,7,16,7"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <Style x:Key="WarningValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Margin" Value="0,7,0,7"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="29"/>
        </Style>
    </Window.Resources>

    <Border Margin="16"
            Padding="24"
            Background="#FFF7ED"
            BorderBrush="#F97316"
            BorderThickness="4"
            CornerRadius="24">
        <Border.Effect>
            <DropShadowEffect Color="#9A3412"
                              BlurRadius="26"
                              ShadowDepth="5"
                              Opacity="0.32"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="76"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <Border Background="#F97316"
                    CornerRadius="14">
                <TextBlock Text="⚠ XÁC NHẬN ĐÓNG THÙNG LẺ"
                           FontSize="42"
                           FontWeight="Black"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center"/>
            </Border>

            <Grid Grid.Row="1"
                  Margin="8,16,8,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="161"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Trạng thái" Style="{StaticResource WarningLabelStyle}" Height="32" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="0" Grid.Column="1"
                           Text="Chưa đủ số lượng tiêu chuẩn"
                           Foreground="#C2410C"
                           FontWeight="Bold"
                           Style="{StaticResource WarningValueStyle}" Margin="0,7,0,7"/>

                <TextBlock Grid.Row="1" Text="Chi tiết" Style="{StaticResource WarningLabelStyle}" Height="32" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <StackPanel Grid.Row="1"
                            Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="0,7,0,7">
                    <TextBlock Text="Số lượng hiện tại: "
                               FontSize="24"
                               Foreground="#0F172A"/>
                    <TextBlock x:Name="txtQuantity"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#C2410C"/>
                </StackPanel>

                <TextBlock Grid.Row="2" Text="Xác nhận" Style="{StaticResource WarningLabelStyle}" Height="32" Margin="0,7,16,0"/>
                <TextBlock Grid.Row="2" Grid.Column="1"
                           Text="Chỉ xác nhận khi thiếu hàng thực tế hoặc kết thúc lô."
                           Style="{StaticResource WarningValueStyle}" Margin="0,7,0,7"/>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="XÁC NHẬN ĐÓNG LẺ"
                        Height="58"
                        FontSize="24"
                        FontWeight="Black"
                        Foreground="White"
                        Background="#F97316"
                        BorderThickness="0"
                        IsDefault="True"
                        Click="BtnConfirm_Click"/>

                <Button Grid.Column="2"
                        Content="↩ QUAY LẠI SCAN"
                        Height="58"
                        FontSize="24"
                        FontWeight="Black"
                        Foreground="White"
                        Background="#2563EB"
                        BorderThickness="0"
                        Click="BtnCancel_Click"/>
            </Grid>
        </Grid>
    </Border>

</Window>
